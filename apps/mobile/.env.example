# API base URL. Required when running on a physical device (phone/tablet).
# On device, use your computer's LAN IP so the app can reach the backend.
# Example: get your IP with `ipconfig getifaddr en0` (Mac) or check WiFi settings.
# If device shows "Could not connect to the server": ensure server is running and firewall allows port 3001.
# If device shows "Connection refused" to Metro: run `pnpm start:mobile` and allow firewall for 8081.
EXPO_PUBLIC_API_URL=http://localhost:3001
