@startuml
!theme plain
skinparam activity {
  BackgroundColor lightblue
  BorderColor black
  FontSize 12
}

title WhatsChat Data Flow Diagram

start

:Client request;

partition "Client Layer" {
  :Web/Mobile Client;
}

partition "Gateway Layer" {
  :API Gateway;
  :Load Balancer;
}

partition "Application Layer" {
  :API Server (NestJS);
  note right
    - Request validation
    - Authentication
    - Business logic
  end note
}

partition "AI/ML Services" {
  :RAG Service;
  :Media Gen Service;
  :Vision Service;
  :Recommendation Service;
}

partition "Data Layer" {
  :PostgreSQL;
  :Redis Cache;
  :Qdrant Vector DB;
  :Cassandra;
  :Object Storage;
}

' User Authentication
partition "Scenario 1: User Login" {
  :Client sends login request;
  :Request reaches API gateway;
  :Load balancer forwards;
  :API Server receives request;
  if (Session in Redis?) then (Yes)
    :Read session from Redis;
    :Return login status;
  else (No)
    :Validate credentials;
    :Query PostgreSQL user info;
    if (Valid?) then (Yes)
      :Generate JWT token;
      :Store session in Redis;
      :Return token to client;
    else (No)
      :Return error;
    endif
  endif
}

' Message Sending
partition "Scenario 2: Send Message" {
  :Client sends message;
  :Request reaches API gateway;
  :Load balancer forwards;
  :API Server receives request;
  :Validate user permissions;
  :Create message record;
  :Write to PostgreSQL;
  :Cache message in Redis;
  :Publish event to Redis Pub/Sub;
  :WebSocket push message;
  :Return success;
}

' RAG Query
partition "Scenario 3: RAG Query" {
  :User submits query;
  :API forwards to RAG Service;
  :RAG generates query vector;
  :RAG queries Qdrant vector DB;
  :RAG calls LLM to generate answer;
  :Return answer and sources;
}

' Media Generation
partition "Scenario 4: Media Generation" {
  :User requests image/video/voice;
  :API forwards to Media Gen;
  :Media Gen calls AI models;
  :Generated files saved to storage;
  :Return media URL;
}

' Vision Moderation
partition "Scenario 5: Content Moderation" {
  :User uploads image/video;
  :API forwards to Vision Service;
  :Vision performs tag prediction;
  :Vision performs NSFW detection;
  :Return moderation result;
}

' Recommendation
partition "Scenario 6: Recommendation Ranking" {
  :User requests feed;
  :API forwards to Recommendation;
  :Recommendation gets candidates from Redis;
  :Ranking model scores candidates;
  :Return ranked results;
}

' File Upload
partition "Scenario 7: File Upload" {
  :Client uploads file;
  :Request reaches API gateway;
  :Load balancer forwards;
  :API Server receives request;
  :Validate file type and size;
  :Upload to object storage;
  :Get file URL;
  :Save metadata to PostgreSQL;
  :Return file URL;
}

' Message Query
partition "Scenario 8: Query Messages" {
  :Client requests history;
  :Request reaches API gateway;
  :Load balancer forwards;
  :API Server receives request;
  if (Cache in Redis?) then (Yes)
    :Read from Redis;
  else (No)
    :Query from PostgreSQL;
    :Cache in Redis;
  endif
  :Return message list;
}

' Real-time Push
partition "Scenario 9: Real-time Push" {
  :API receives new message;
  :Publish event to Redis Pub/Sub;
  note right
    **Event Topics**
    - message:new
    - message:updated
    - user:online
    - user:offline
  end note
  :WebSocket service subscribes;
  :Push to online users;
  :Client receives message;
}

' Call Signaling
partition "Scenario 10: Voice/Video Call (WebRTC)" {
  :Caller initiates call;
  :WebSocket sends call-offer;
  :API/WebSocket forwards to callee;
  :Callee WebSocket receives offer;
  :Callee creates answer via WebSocket;
  :Both exchange ICE candidates (WebSocket);
  :Establish P2P WebRTC media channel;
  note right
    Media flows peer-to-peer
    (or via STUN/TURN)
  end note
}

stop

note right
  **Service Ports**
  - API Server: :3001
  - RAG Service: :8002
  - Media Gen: :3456
  - Vision: :8001
  - Recommendation: :8000
  
  **Data Flow Summary**
  
  1. **Auth**: Client -> Gateway -> API -> PostgreSQL/Redis
  2. **Messages**: Client -> API -> PostgreSQL -> Redis Pub/Sub -> WebSocket -> Client
  3. **RAG**: Query -> RAG -> Qdrant -> LLM -> Answer
  4. **Media Gen**: Request -> Media Gen -> AI Models -> Storage -> URL
  5. **Moderation**: Upload -> Vision -> Tags/NSFW -> Result
  6. **Recommendation**: Request -> Recommendation -> Redis/Cassandra -> Rank -> Result
  7. **File Upload**: Client -> API -> Object Storage -> PostgreSQL
  8. **Message Query**: Client -> API -> Redis Cache / PostgreSQL
  9. **Real-time Push**: API -> Redis Pub/Sub -> WebSocket -> Client
  10. **Calls**: Signaling via WebSocket; media via WebRTC P2P (optional STUN/TURN)
  
  **Shared Types**: Domain types (User, Message, Chat, Call, etc.) used by API and clients are defined in @whatschat/domain.
end note

@enduml

