@startuml
!theme plain
skinparam linetype ortho
skinparam componentStyle rectangle

title WhatsChat Entity-Relationship Diagram

package "PostgreSQL (Prisma)" as PG #E8F4FD {

  entity "User" as User {
    * id : cuid
    --
    username : string
    email : string
    phone : string?
    password : string
    avatar : string?
    status : string?
    isOnline : boolean
    lastSeen : datetime
    createdAt : datetime
    updatedAt : datetime
  }

  entity "UserFollow" as UserFollow {
    * id : cuid
    --
    * followerId : string
    * followingId : string
    createdAt : datetime
  }

  entity "Chat" as Chat {
    * id : cuid
    --
    type : ChatType
    name : string?
    avatar : string?
    createdAt : datetime
    updatedAt : datetime
  }

  entity "ChatParticipant" as ChatParticipant {
    * id : cuid
    --
    * chatId : string
    * userId : string
    role : ParticipantRole
    joinedAt : datetime
    addedBy : string?
    isArchived : boolean
    isMuted : boolean
    muteUntil : datetime?
  }

  entity "Message" as Message {
    * id : cuid
    --
    * chatId : string
    * senderId : string
    type : MessageType
    content : string
    mediaUrl : string?
    thumbnailUrl : string?
    duration : int?
    size : int?
    isEdited : boolean
    isDeleted : boolean
    replyToMessageId : string?
    createdAt : datetime
    updatedAt : datetime
  }

  entity "MessageReaction" as MessageReaction {
    * id : cuid
    --
    * messageId : string
    * userId : string
    emoji : string
    createdAt : datetime
  }

  entity "MessageRead" as MessageRead {
    * id : cuid
    --
    * messageId : string
    * userId : string
    readAt : datetime
  }

  entity "Group" as Group {
    * id : cuid
    --
    name : string
    description : string?
    avatar : string?
    * creatorId : string
    createdAt : datetime
    updatedAt : datetime
  }

  entity "GroupParticipant" as GroupParticipant {
    * id : cuid
    --
    * groupId : string
    * userId : string
    role : ParticipantRole
    joinedAt : datetime
    addedBy : string?
  }

  entity "Call" as Call {
    * id : cuid
    --
    type : CallType
    status : CallStatus
    * initiatorId : string
    chatId : string?
    startTime : datetime
    endTime : datetime?
    duration : int?
    createdAt : datetime
  }

  entity "Meeting" as Meeting {
    * id : cuid
    --
    * callId : string
    chimeMeetingId : string
    chimeMeetingArn : string?
    createdAt : datetime
    endedAt : datetime?
  }

  entity "MeetingAttendee" as MeetingAttendee {
    * id : cuid
    --
    * meetingId : string
    * userId : string
    chimeAttendeeId : string
    joinedAt : datetime
    leftAt : datetime?
  }

  entity "CallParticipant" as CallParticipant {
    * id : cuid
    --
    * callId : string
    * userId : string
    status : CallParticipantStatus
    joinedAt : datetime?
    leftAt : datetime?
  }

  entity "Status" as Status {
    * id : cuid
    --
    * userId : string
    type : StatusType
    content : string
    mediaUrl : string?
    expiresAt : datetime
    createdAt : datetime
  }

  entity "StatusView" as StatusView {
    * id : cuid
    --
    * statusId : string
    * userId : string
    viewedAt : datetime
  }

  entity "Contact" as Contact {
    * id : cuid
    --
    * ownerId : string
    name : string
    phone : string?
    email : string?
    avatar : string?
    createdAt : datetime
    updatedAt : datetime
  }

  entity "BlockedUser" as BlockedUser {
    * id : cuid
    --
    * blockedById : string
    * blockedId : string
    createdAt : datetime
  }

  entity "Notification" as Notification {
    * id : cuid
    --
    * userId : string
    type : NotificationType
    title : string
    body : string
    data : json?
    isRead : boolean
    createdAt : datetime
  }

  entity "UserSettings" as UserSettings {
    * id : cuid
    --
    * userId : string
    theme : string
    language : string
    notifications : json
    privacy : json
    chat : json
    updatedAt : datetime
  }

  entity "FileUpload" as FileUpload {
    * id : cuid
    --
    originalName : string
    filename : string
    mimetype : string
    size : int
    url : string
    thumbnailUrl : string?
    * uploadedBy : string
    createdAt : datetime
  }

  entity "AnalyticsEvent" as AnalyticsEvent {
    * id : cuid
    --
    userId : string?
    eventName : string
    properties : json?
    platform : string?
    sessionId : string?
    createdAt : datetime
  }

  User ||--o{ UserFollow : "follower"
  User ||--o{ UserFollow : "following"
  User ||--o{ ChatParticipant : ""
  User ||--o{ Message : "sentMessages"
  User ||--o{ GroupParticipant : ""
  User ||--o{ Group : "createdGroups"
  User ||--o{ CallParticipant : ""
  User ||--o{ Call : "initiatedCalls"
  User ||--o{ Status : ""
  User ||--o{ StatusView : ""
  User ||--o{ Contact : "contacts"
  User ||--o{ BlockedUser : "blockedUsers"
  User ||--o{ BlockedUser : "blockedByUsers"
  User ||--o{ Notification : ""
  User ||--o| UserSettings : ""
  User ||--o{ FileUpload : ""
  User ||--o{ MeetingAttendee : ""

  Chat ||--o{ ChatParticipant : ""
  Chat ||--o{ Message : ""
  Chat ||--o{ Call : ""

  Message ||--o{ MessageReaction : ""
  Message ||--o{ MessageRead : ""
  Message }o--o| Message : "replyTo"

  Group ||--o{ GroupParticipant : ""

  Call ||--o{ CallParticipant : ""
  Call ||--o| Meeting : ""

  Meeting ||--o{ MeetingAttendee : ""

  Status ||--o{ StatusView : ""
}

package "Cassandra" as CS #FFF9E6 {

  entity "posts" as Posts {
    * user_id : text
    * created_at : timestamp
    * post_id : text
    --
    caption : text
    type : text
    media_urls : list<text>
    location : text
  }

  entity "post_by_id" as PostById {
    * post_id : text
    --
    user_id : text
    created_at : timestamp
    caption : text
    type : text
    media_urls : list<text>
    location : text
  }

  entity "feed_by_user" as FeedByUser {
    * user_id : text
    * created_at : timestamp
    * post_id : text
    --
    author_id : text
  }

  Posts .. PostById : "same post"
  FeedByUser .. Posts : "references post"
}

package "MongoDB" as MG #E8F8E8 {

  entity "comments" as Comments {
    * _id : ObjectId
    --
    * postId : string
    * userId : string
    * content : string
    parentId : string?
    createdAt : datetime
    updatedAt : datetime
  }

  Comments }o--o| Comments : "parentId reply"
}

package "Logical refs (cross-store)" as REF #F0F0F0 {
  note as N1
    **PostgreSQL User** id is referenced by:
    - Cassandra posts.user_id, feed_by_user.user_id, feed_by_user.author_id
    - MongoDB comments.userId
    **Cassandra** post_id is referenced by:
    - MongoDB comments.postId
  end note
}

User .. N1 : "id"
Posts .. N1 : "user_id"
FeedByUser .. N1 : "user_id, author_id"
Comments .. N1 : "postId, userId"

@enduml
