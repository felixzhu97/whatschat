@startuml Wardley_Map

!theme plain

skinparam linetype ortho

skinparam packageStyle rectangle

title WhatsChat Messaging Platform – Wardley Map

' ============================================
' Value chain and evolution
' ============================================
'
' Y: Value chain – user needs to infrastructure
' X: Evolution – Genesis → Custom Built → Product → Commodity
'

package "User needs" #E3F2FD {
  class UserNeeds {
    + Messaging needs
    + Voice/video needs
    + File sharing needs
    --
    Real-time messaging
    Voice and video calls
    Media and file sharing
    Group chat
    Message search
  }
}

package "Application" #BBDEFB {
  class WebApplication {
    + Web app
    --
    Next.js 15 + React 19
    Responsive UI
    Real-time messages
    Voice/video UI
    File upload/download
  }
  
  class MobileApplication {
    + Mobile app
    --
    Flutter cross-platform
    Native feel
    Push notifications
    Offline messages
    Media playback
  }
}

package "Platform" #90CAF9 {
  class MessageService {
    + Messaging service
    --
    Real-time routing
    Message persistence
    Message status
    Push delivery
  }
  
  class AuthService {
    + Auth service
    --
    JWT management
    Passport strategies
    Session management
    Access control
  }
  
  class CallService {
    + Call service
    --
    WebRTC signalling
    Call state
    Media negotiation
    Call history
  }
  
  class FileService {
    + File service
    --
    Upload/download
    Storage management
    Preview
    Access control
  }
  
  class SearchService {
    + Search service
    --
    Full-text search
    Message history
    Contact search
    Recommendations
  }
  
  class NotificationService {
    + Push service
    --
    FCM/APNs
    Message push
    Offline notifications
    Push stats
  }
}

package "Infrastructure" #64B5F6 {
  class DatabaseService {
    + Database
    --
    PostgreSQL primary
    Persistence
    Backup and restore
    Read/write split
  }
  
  class CacheService {
    + Cache
    --
    Redis
    Session cache
    Message queue
    Real-time state
  }
  
  class StorageService {
    + Storage
    --
    Local file storage
    File store
    Media management
    CDN integration
  }
  
  class SearchEngine {
    + Search engine
    --
    Elasticsearch
    Full-text index
    Search tuning
    Data sync
  }
  
  class WebSocketService {
    + WebSocket
    --
    Socket.io
    Real-time comms
    Connection management
    Broadcast
  }
  
  class WebRTCService {
    + WebRTC
    --
    P2P comms
    STUN/TURN
    Media handling
    NAT traversal
  }
  
  class CDNService {
    + CDN
    --
    Static asset delivery
    Global distribution
    Caching
    Load balancing
  }
  
  class ContainerService {
    + Containers
    --
    Docker
    Kubernetes
    Auto-scaling
    Service discovery
  }
}

