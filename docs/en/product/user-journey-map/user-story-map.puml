@startuml User_Story_Map

!theme plain

skinparam linetype ortho
skinparam packageStyle rectangle

title WhatsChat User Story Map

' ============================================
' Auth and account
' ============================================

package "Auth & account" #E3F2FD {
  class AuthEpic {
    + Epic: Auth & account
    --
    As a user
    I want to register and log in securely
    so I can use all WhatsChat features
  }
  
  class AuthStories {
    + User stories
    --
    1. Register
    2. Log in
    3. Password reset
    4. Profile management
    5. Avatar upload
    6. Change password
  }
  
  class AuthCriteria {
    + Acceptance criteria
    --
    - Form validation
    - JWT management
    - Encrypted password storage
    - Profile updates apply immediately
  }
}

AuthEpic --> AuthStories
AuthStories --> AuthCriteria

' ============================================
' Contact management
' ============================================

package "Contact management" #BBDEFB {
  class ContactEpic {
    + Epic: Contact management
    --
    As a user
    I want to manage my contacts
    so I can find and message them quickly
  }
  
  class ContactStories {
    + User stories
    --
    1. Add contact
    2. Search contacts
    3. View contact details
    4. Remove contact
    5. Contact groups
    6. Blocklist
  }
  
  class ContactCriteria {
    + Acceptance criteria
    --
    - Multiple search options
    - Real-time contact status
    - Complete contact info
    - Immediate feedback
  }
}

ContactEpic --> ContactStories
ContactStories --> ContactCriteria

' ============================================
' Messaging
' ============================================

package "Messaging" #90CAF9 {
  class MessageEpic {
    + Epic: Real-time messaging
    --
    As a user
    I want to send and receive messages in real time
    so I can stay in touch with contacts
  }
  
  class MessageStories {
    + User stories
    --
    1. Send text
    2. Send media (image, video, audio, file)
    3. Receive notifications
    4. Message status (sent, delivered, read)
    5. Search messages
    6. Delete and recall
    7. Forward
    8. Star and mark unread
    9. Voice message
    10. Share location
  }
  
  class MessageCriteria {
    + Acceptance criteria
    --
    - Real-time sync
    - Multiple message types
    - Accurate status
    - Strong search
    - Encrypted in transit
  }
}

MessageEpic --> MessageStories
MessageStories --> MessageCriteria

' ============================================
' Voice and video calls
' ============================================

package "Voice & video calls" #64B5F6 {
  class CallEpic {
    + Epic: Voice and video calls
    --
    As a user
    I want high-quality voice and video calls
    so I can communicate in real time
  }
  
  class CallStories {
    + User stories
    --
    1. Start voice call
    2. Start video call
    3. Accept/reject call
    4. In-call (mute, camera)
    5. Call history
    6. Missed-call reminder
    7. Group calls
    8. Call quality tuning
  }
  
  class CallCriteria {
    + Acceptance criteria
    --
    - Stable WebRTC
    - Low latency
    - Clear audio/video
    - Accurate call state
    - Multi-device
  }
}

CallEpic --> CallStories
CallStories --> CallCriteria

' ============================================
' Groups
' ============================================

package "Groups" #42A5F5 {
  class GroupEpic {
    + Epic: Group chat and management
    --
    As a user
    I want to create and manage groups
    so I can collaborate and chat with many people
  }
  
  class GroupStories {
    + User stories
    --
    1. Create group
    2. Invite members
    3. Remove members
    4. Set name, avatar, description
    5. Send group messages
    6. @mention
    7. Permissions
    8. Leave group
    9. Dissolve group
    10. Announcements
  }
  
  class GroupCriteria {
    + Acceptance criteria
    --
    - Large groups (100+)
    - Precise permissions
    - Real-time member updates
    - Searchable group info
  }
}

GroupEpic --> GroupStories
GroupStories --> GroupCriteria

' ============================================
' Status
' ============================================

package "Status" #1E88E5 {
  class StatusEpic {
    + Epic: Status updates
    --
    As a user
    I want to post and view status updates
    so I can share what I am doing
  }
  
  class StatusStories {
    + User stories
    --
    1. Post text status
    2. Post image/video status
    3. View contact status
    4. Status privacy
    5. Expiry (e.g. 24h)
    6. View stats
  }
  
  class StatusCriteria {
    + Acceptance criteria
    --
    - Auto-expiry
    - Flexible privacy
    - Media support
    - Accurate stats
  }
}

StatusEpic --> StatusStories
StatusStories --> StatusCriteria

' ============================================
' Settings and privacy
' ============================================

package "Settings & privacy" #0D47A1 {
  class SettingsEpic {
    + Epic: Settings and privacy
    --
    As a user
    I want to customise settings and control privacy
    so I have a better experience and security
  }
  
  class SettingsStories {
    + User stories
    --
    1. Profile settings
    2. Privacy (last seen, avatar)
    3. Notifications
    4. Chat (wallpaper, theme)
    5. Storage management
    6. Security
    7. Data export
    8. Account deletion
  }
  
  class SettingsCriteria {
    + Acceptance criteria
    --
    - Clear categories
    - Detailed privacy options
    - Settings apply immediately
    - Reliable data handling
  }
}

SettingsEpic --> SettingsStories
SettingsStories --> SettingsCriteria

' ============================================
' Priority
' ============================================

package "Priority" #FFF9C4 {
  class Priority {
    + MVP
    --
    Auth & account
    Contact management (basic)
    Messaging (text)
    Basic settings
  }
  
  class Priority2 {
    + Phase 1
    --
    Media messages
    Voice/video calls
    Groups (basic)
    Status
  }
  
  class Priority3 {
    + Phase 2
    --
    Advanced search
    Group management
    File sharing improvements
    Privacy enhancements
  }
  
  class Priority4 {
    + Future
    --
    Enterprise features
    Third-party integration
    AI assistant
    Advanced analytics
  }
}

AuthEpic ..> Priority : Part of
ContactEpic ..> Priority : Part of
MessageEpic ..> Priority : Part of
MessageEpic ..> Priority2 : Part of
CallEpic ..> Priority2 : Part of
GroupEpic ..> Priority2 : Part of
StatusEpic ..> Priority2 : Part of
SettingsEpic ..> Priority : Part of
SettingsEpic ..> Priority3 : Part of

' ============================================
' Dependencies
' ============================================

AuthEpic --> ContactEpic : Must complete first
ContactEpic --> MessageEpic : Must complete first
MessageEpic --> CallEpic : Can run in parallel
MessageEpic --> GroupEpic : Can run in parallel
MessageEpic --> StatusEpic : Can run in parallel
SettingsEpic --> AuthEpic : Depends on auth

' ============================================
' Acceptance examples
' ============================================

note right of AuthStories
  **Register**
  
  Given: User visits signup page
  When: Submits valid data
  Then:
  - Account created
  - Verification email sent
  - Redirect to login
end note

note right of MessageStories
  **Send message**
  
  Given: User logged in, contact selected
  When: Types and sends
  Then:
  - Message appears in chat
  - Status "sent"
  - Recipient gets notification
  - Status "delivered"
end note

note right of CallStories
  **Start call**
  
  Given: User logged in, contact selected
  When: Clicks voice/video
  Then:
  - Recipient gets call
  - WebRTC established
  - Call UI shown
  - Mute, hang up work
end note

' ============================================
' Summary
' ============================================

legend right
  |<#E3F2FD> Auth & account | MVP |
  |<#BBDEFB> Contact | MVP |
  |<#90CAF9> Messaging | MVP |
  |<#64B5F6> Voice/video | Phase 1 |
  |<#42A5F5> Groups | Phase 1 |
  |<#1E88E5> Status | Phase 1 |
  |<#0D47A1> Settings & privacy | MVP + enhancements |
  |
  |Priority | MVP → Phase 1 → Phase 2 → Future |
endlegend

@enduml
