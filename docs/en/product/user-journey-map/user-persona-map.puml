@startuml User_Persona_Map

!theme plain

skinparam linetype ortho
skinparam packageStyle rectangle

title WhatsChat User Persona Map

' ============================================
' Personas
' ============================================

package "Regular User" #E3F2FD {
  class RegularUser {
    + Profile
    --
    Age: 25–40
    Role: Office, student, freelancer
    Tech: Medium
    Frequency: 1–3x/day
    --
    Scenarios:
    - Chat with friends and family
    - Share photos and videos
    - Occasional voice calls
    --
    Needs:
    - Simple UI
    - Reliable messaging
    - Basic privacy
    --
    Pain points:
    - Too many features
    - Occasional sync delay
    --
    Preferences:
    - Text messages
    - Image sharing
    - Simple settings
  }
}

package "Active User" #BBDEFB {
  class ActiveUser {
    + Profile
    --
    Age: 20–35
    Role: Tech, entrepreneur
    Tech: High
    Frequency: Multiple times/day
    --
    Scenarios:
    - Frequent group chats
    - Work collaboration
    - Voice/video meetings
    - File transfer
    --
    Needs:
    - Efficient message management
    - Strong search
    - Multi-device sync
    - Group management
    --
    Pain points:
    - Too many messages
    - Weak search
    - Complex group actions
    --
    Preferences:
    - All message types
    - Groups
    - Advanced search
    - Mark and archive
  }
}

package "Group Admin" #90CAF9 {
  class GroupAdmin {
    + Profile
    --
    Age: 25–45
    Role: Team lead, community admin
    Tech: Medium–high
    Frequency: Multiple times/day
    --
    Scenarios:
    - Manage multiple groups
    - Organise activities
    - Announcements
    - Resolve conflicts
    --
    Needs:
    - Member management
    - Permission control
    - Group settings
    - Activity stats
    --
    Pain points:
    - Limited admin tools
    - No bulk actions
    - Lack of analytics
    --
    Preferences:
    - Group management
    - Member permissions
    - Group announcements
    - Moderation (if needed)
  }
}

package "Enterprise User" #64B5F6 {
  class EnterpriseUser {
    + Profile
    --
    Age: 30–50
    Role: Employee, manager
    Tech: Medium
    Frequency: Heavy on workdays
    --
    Scenarios:
    - Internal team chat
    - Project collaboration
    - Customer communication
    - File sharing
    --
    Needs:
    - Enterprise security
    - Encryption and backup
    - Team management
    - Third-party integration
    --
    Pain points:
    - Missing enterprise features
    - Data security concerns
    - No office system integration
    --
    Preferences:
    - Secure comms
    - File management
    - Team collaboration
    - Data export
  }
}

' ============================================
' Persona relationships
' ============================================

RegularUser --> ActiveUser : May become
ActiveUser --> GroupAdmin : May become
GroupAdmin --> EnterpriseUser : May become

' ============================================
' Needs matrix
' ============================================

package "Need priorities" #FFF9C4 {
  class NeedsMatrix {
    + Regular user needs
    --
    High:
    - Send/receive messages
    - Contact management
    - Basic settings
    --
    Medium:
    - Image sharing
    - Voice messages
    - Status updates
    --
    Low:
    - Video calls
    - Groups
    - Advanced search
  }
  
  class ActiveNeeds {
    + Active user needs
    --
    High:
    - Message search
    - Group management
    - Multi-device sync
    --
    Medium:
    - File sharing
    - Voice/video calls
    - Archive
    --
    Low:
    - Personalisation
    - Themes
  }
  
  class AdminNeeds {
    + Admin needs
    --
    High:
    - Member management
    - Permissions
    - Group settings
    --
    Medium:
    - Moderation
    - Stats
    - Bulk actions
    --
    Low:
    - Custom features
    - Advanced analytics
  }
  
  class EnterpriseNeeds {
    + Enterprise needs
    --
    High:
    - Data security
    - Team management
    - Compliance
    --
    Medium:
    - Integrations
    - Backup
    - Audit logs
    --
    Low:
    - Custom dev
    - On-premise
  }
}

RegularUser ..> NeedsMatrix : Needs
ActiveUser ..> ActiveNeeds : Needs
GroupAdmin ..> AdminNeeds : Needs
EnterpriseUser ..> EnterpriseNeeds : Needs

' ============================================
' Scenario mapping
' ============================================

package "Scenarios" #FFE0B2 {
  class Scenarios {
    + Personal comms
    --
    One-to-one chat
    Family groups
    Status updates
    Voice calls
  }
  
  class WorkScenarios {
    + Work collaboration
    --
    Team groups
    Project discussion
    File sharing
    Video meetings
  }
  
  class SocialScenarios {
    + Social
    --
    Interest groups
    Events
    Content sharing
    Community
  }
}

RegularUser --> Scenarios : Main use
ActiveUser --> Scenarios : Use
ActiveUser --> WorkScenarios : Main use
GroupAdmin --> WorkScenarios : Main use
GroupAdmin --> SocialScenarios : Use
EnterpriseUser --> WorkScenarios : Main use

' ============================================
' Feature usage
' ============================================

note right of RegularUser
  **Usage**
  
  High: Text, images
  Medium: Voice, status
  Low: Video, group admin
end note

note right of ActiveUser
  **Usage**
  
  High: All message types, groups
  Medium: Search, files, calls
  Low: Personalisation
end note

note right of GroupAdmin
  **Usage**
  
  High: Group admin, members
  Medium: Posts, permissions
  Low: Personal chat
end note

note right of EnterpriseUser
  **Usage**
  
  High: Team comms, files
  Medium: Data, security
  Low: Personal social
end note

' ============================================
' Summary
' ============================================

legend right
  |<#E3F2FD> Regular | Daily chat, simple |
  |<#BBDEFB> Active | Heavy use, full features |
  |<#90CAF9> Group Admin | Groups, permissions |
  |<#64B5F6> Enterprise | Teams, security first |
  |
  |Frequency | 1–3x/day → Multiple/day |
  |Tech | Medium → High |
  |Needs | Basic → Advanced |
endlegend

@enduml
