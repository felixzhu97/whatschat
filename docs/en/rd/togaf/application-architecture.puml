@startuml
!theme plain
skinparam componentStyle rectangle
skinparam linetype ortho

title TOGAF Application Architecture - WhatsChat Messaging System

package "Shared Packages" {
  component [@whatschat/domain] as DomainPkg #LightYellow
  note right of DomainPkg
    Shared domain types:
    User, Message, Chat,
    Contact, Group, Call
  end note
  
  component [@whatschat/im] as ImPkg #LightCyan
  note right of ImPkg
    Chat: slices, useRealChat,
    useChatsWithLiveMessages.
    RTC: useCall, createCallManager.
    Re-exports @whatschat/rtc.
  end note
  
  component [@whatschat/rtc] as RtcPkg #LightGreen
  note right of RtcPkg
    Config-driven RTC:
    RTCCallState, ICallManager,
    createCallManager(config).
    Apps inject signaling,
    media, API adapters.
  end note
}

ImPkg --> DomainPkg : uses types
ImPkg --> RtcPkg : depends on

package "Client Applications" {
  component [Web App] as WebApp #LightBlue
  note right of WebApp
    Tech stack:
    - Next.js 15
    - React 19
    - TypeScript
    - Tailwind CSS
    - Redux Toolkit + React Redux
    Features: feed (engagement ranking, like/save), Reels,
    explore tab, create post (multi media), comments dialog,
    profile (followers/following modals, infinite scroll, isFollowing), i18n
  end note
  
  component [Admin App] as AdminApp #LightGray
  note right of AdminApp
    Tech stack:
    - Next.js 15
    - React 19
    - TypeScript
    - Emotion (styled)
    - AG Grid (tables)
    - Recharts (charts)
    - i18next (en/zh)
    - Theme (light/dark)
  end note
  
  component [Mobile App] as MobileApp #LightGreen
  note right of MobileApp
    Tech stack:
    - React Native
    - Expo
    - TypeScript
    - Emotion (@emotion/native)
    - Redux Toolkit + React Redux
    - i18next (en/zh)
    - Theme (light/dark/system)
    - iOS-style Settings (grouped cards)
  end note
}

WebApp --> ImPkg : chat + RTC
WebApp --> DomainPkg : uses types
AdminApp --> DomainPkg : uses types
MobileApp --> ImPkg : chat + RTC
MobileApp --> DomainPkg : uses types

package "API Gateway Layer" {
  component [REST API Gateway] as RestGateway
  component [WebSocket Gateway] as WsGateway
  component [WebRTC Signaling] as WebRTCGateway
}

package "Application Services Layer" {
  component [Auth Service] as AuthService
  component [User Service] as UserService
  component [Message Service] as MessageService
  component [Chat Service] as ChatService
  component [Post Service] as PostService
  component [Feed Service] as FeedService
  component [Explore Service] as ExploreService
  component [Follow Service] as FollowService
  component [Comment Service] as CommentService
  component [Call Service] as CallService
  component [Group Service] as GroupService
  component [Status Service] as StatusService
  component [File Service] as FileService
  component [Notification Service] as NotificationService
}

package "Recommendation Application" {
  component [Recommendation Jobs] as RecJobs #LightYellow
  note right of RecJobs
    Python (apps/recommendation)
    Celery worker + beat
    LightFM, implicit (ALS), Annoy
    Batch: suggestions, explore hot list
    Writes to Redis
  end note
}

AuthService --> DomainPkg : uses types
MessageService --> DomainPkg : uses types
ChatService --> DomainPkg : uses types
package "Business Logic Layer" {
  component [Message Handling Logic] as MessageLogic
  component [Realtime Communication Logic] as RealtimeLogic
  component [Authorization Logic] as AuthzLogic
  component [Business Rules Engine] as BusinessRules
}

package "Data Access Layer" {
  component [Data Repository] as DataRepository
  component [Cache Service] as CacheService
  component [Post/Feed Repository] as PostFeedRepo
  component [Comment Repository] as CommentRepo
}

package "Infrastructure Services" {
  database [PostgreSQL] as PostgreSQL
  database [Redis] as Redis
  database [Cassandra] as Cassandra
  database [MongoDB] as MongoDB
  database [Elasticsearch] as Elasticsearch
  component [File Storage] as FileStorage
  component [Search Service] as SearchService
}

