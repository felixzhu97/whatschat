@startuml
!global RELATIVE_INCLUDE = 1
!include ../../../c4-lib/C4-PlantUML/C4_Component.puml

title C4 Level 3 - Components: Mobile Application (Expo)

Container_Boundary(mobile_app, "Mobile Application") {
  Component(screens, "Screens", "Expo Router", "Tabs: Status (Home + Stories), Reels, Chats (DM), Explore (search + grid), Profile; stack: settings-menu (Settings and activity), create-post, media-viewer, notifications, inbox, chat-detail, login")
  Component(chat_ui, "Chat UI", "React Native, Emotion", "DM list (Instagram-style rows), message list, input, bubbles")
  Component(feed_ui, "Status/Home Feed UI", "React Native, Emotion", "Instagram-style header, horizontal stories, vertical feed with photos/videos, multi-media carousel with horizontal swipe per post, pull-to-refresh, infinite scroll, Status tab tap-to-scroll-top")
  Component(reels_ui, "Reels UI", "React Native, Emotion", "Vertical video feed with snap paging, like/save, pause/play, follow/caption overlay, mute toggle")
  Component(explore_ui, "Search / Explore UI", "React Native, Emotion", "Explore grid (REST /posts/explore), post search (Elasticsearch /search), media-viewer navigation")
  Component(profile_ui, "Profile UI", "React Native, Emotion", "Instagram-style profile: header, avatar/stats, discover people, grid / Reels / tagged tabs, user posts via REST /posts/user/:id")
  Component(settings_activity_ui, "Settings & activity UI", "React Native, Emotion", "Instagram-style settings: search bar, sectioned list, theme, language, notifications link, add account, log out")
  Component(create_post_ui, "Create Post UI", "React Native, Emotion", "Select photos/videos, caption, optional video cover, upload media via /media/upload then create post")
  Component(call_ui, "Call UI", "React Native, WebRTC", "Voice/video call UI; useCall from @whatschat/im")
  Component(auth_hooks, "Auth Hooks", "Redux Toolkit + React Redux", "Login state, token refresh")
  Component(message_hooks, "Message Hooks", "@whatschat/im + Redux", "useChatsWithLiveMessages, message slices")
  Component(feed_hooks, "Feed Hooks", "React Hooks + GraphQL", "useMobileFeed/useMobileStories; debounced pagination, pull-to-refresh, shared GraphQL feed query with web")
  Component(reels_hooks, "Reels Hooks", "React Hooks + GraphQL", "useGetReelsFirst/useLazyGetReelsMore; pagination, like/unlike mutations")
  Component(feed_domain, "Feed & Explore Client", "FeedService + RTK feedApi", "GraphQL feed/reels; REST explore, search, getPostById, getUserProfile, getUserPosts, getSuggestions; used by Profile, Explore, media-viewer fallback")
  Component(i18n, "i18n", "i18next, react-i18next", "en/zh locales, language picker")
  Component(theme, "Theme", "Context + AsyncStorage", "Light/dark/system, theme-aware layout")
  Component(api_client, "API Client", "Fetch/axios + GraphQL", "REST/GraphQL calls to API Server")
  Component(ws_client, "WebSocket Client", "Socket.IO", "Realtime connection")
  Component(video_player, "Video Player", "expo-video", "Auto-play/pause videos in feed when visible, mute toggle; one active player per screen")
  Component(analytics_client, "Analytics Client", "@whatschat/analytics", "Tracks feed view/like/save, video play/complete, ad_impression/ad_click for web/mobile parity")
  Component(rtc_config, "RTC Config", "callManagerLoader + mobile-rtc-config", "createCallManager(createMobileRTCConfig()), setSocket")
  Component(im_pkg, "IM Package", "@whatschat/im", "Chat + RTC (packages/im/src/rtc, re-exported at package entry)")
  Component(domain_types, "Domain Types", "@whatschat/domain", "User, Message, Chat, Contact, Call")
}

Container_Ext(api_server, "API Server", "NestJS", "Backend API")
Person(user, "Mobile User", "Uses the app")

Rel(user, screens, "Uses")
Rel(screens, chat_ui, "Renders")
Rel(screens, feed_ui, "Renders")
Rel(screens, reels_ui, "Renders")
Rel(screens, explore_ui, "Renders")
Rel(screens, profile_ui, "Renders")
Rel(screens, settings_activity_ui, "Renders")
Rel(screens, create_post_ui, "Renders")
Rel(screens, call_ui, "Renders")
Rel(chat_ui, message_hooks, "Uses")
Rel(chat_ui, auth_hooks, "Uses")
Rel(chat_ui, i18n, "Uses")
Rel(chat_ui, theme, "Uses")
Rel(feed_ui, feed_hooks, "Uses")
Rel(feed_ui, video_player, "Uses for videos")
Rel(feed_ui, analytics_client, "Sends feed/video/ad events")
Rel(feed_hooks, feed_domain, "Uses")
Rel(feed_hooks, api_client, "GraphQL feed + stories")
Rel(reels_ui, auth_hooks, "Uses")
Rel(reels_ui, reels_hooks, "Uses")
Rel(reels_ui, video_player, "Uses for videos")
Rel(reels_ui, analytics_client, "Sends reel/video/ad events")
Rel(reels_hooks, feed_domain, "Uses")
Rel(reels_hooks, api_client, "GraphQL reels + pagination")
Rel(explore_ui, feed_domain, "Uses")
Rel(explore_ui, auth_hooks, "Uses")
Rel(explore_ui, analytics_client, "Uses")
Rel(profile_ui, feed_domain, "Uses")
Rel(profile_ui, auth_hooks, "Uses")
Rel(profile_ui, i18n, "Uses")
Rel(profile_ui, theme, "Uses")
Rel(settings_activity_ui, i18n, "Uses")
Rel(settings_activity_ui, theme, "Uses")
Rel(create_post_ui, api_client, "uploadMedia + createPost")
Rel(feed_domain, api_client, "HTTPS")
Rel(call_ui, auth_hooks, "Uses")
Rel(call_ui, im_pkg, "useCall")
Rel(call_ui, rtc_config, "getCallManager")
Rel(rtc_config, im_pkg, "createCallManager")
Rel(rtc_config, ws_client, "Signaling via setSocket")
Rel(message_hooks, api_client, "Calls")
Rel(message_hooks, ws_client, "Subscribes")
Rel(message_hooks, im_pkg, "Uses")
Rel(message_hooks, domain_types, "Uses types")
Rel(chat_ui, im_pkg, "Uses")
Rel(chat_ui, domain_types, "Uses types")
Rel(auth_hooks, api_client, "Calls")
Rel(analytics_client, api_client, "Sends analytics_events")
Rel(api_client, api_server, "HTTPS")
Rel(ws_client, api_server, "WebSocket")

SHOW_LEGEND()
@enduml
