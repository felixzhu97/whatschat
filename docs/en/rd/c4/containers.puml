@startuml
!global RELATIVE_INCLUDE = 1
!include ../../../c4-lib/C4-PlantUML/C4_Container.puml

title C4 Level 2 - Containers: WhatsChat

Person(user_web, "Web User", "Uses chat via browser")
Person(user_mobile, "Mobile User", "Uses chat via app")

System_Boundary(whatschat, "WhatsChat") {
  Container(web_app, "Web Application", "Next.js, React, TypeScript, Emotion, i18next", "Instagram-style UI (nav, feed, Reels, profile, sidebar), chat, calls, contacts, auth, AI dialogs; video pause/play in feed and comments")
  Container(admin_app, "Admin Application", "Next.js, React, TypeScript, Emotion, AG Grid, Recharts, i18next", "Dashboard, Users, Content Safety, Ops Monitor, Business, Analytics, System Config, Permission & Audit")
  Container(mobile_app, "Mobile Application", "React Native, Expo, TypeScript, Emotion", "Chat UI, calls, contacts, auth")
  Container(api_server, "API Server", "NestJS, TypeScript", "REST API, WebSocket, auth, business logic, analytics, AI text/image/video/voice proxy")
  Container(media_gen, "Media Gen Service", "Python, FastAPI, diffusers, CogVideoX, edge-tts", "Image, video, voice (TTS), :3456")
  ContainerDb(postgres, "PostgreSQL", "Relational DB", "Users, messages, chats, groups, follow")
  ContainerDb(redis, "Redis", "Cache & Pub/Sub", "Sessions, presence, feed cache, Pub/Sub")
  ContainerDb(kafka, "Kafka", "Message Queue", "Offline messages, post.created events")
  ContainerDb(cassandra, "Cassandra", "Wide-column", "Posts, feed by user")
  ContainerDb(mongodb, "MongoDB", "Document DB", "Comments")
  ContainerDb(elasticsearch, "Elasticsearch", "Search", "Post/user/hashtag search")
  Container_Ext(file_storage, "File Storage", "Local", "Files, media")
  Container_Ext(growthbook, "GrowthBook", "A/B & feature flags", "Feature toggles, experiments")
  Container_Ext(ollama, "Ollama", "LLM runtime", "Streaming chat, optional")
}

Person(admin_user, "Admin User", "Manages system via admin dashboard")

Rel(user_web, web_app, "Uses", "HTTPS, WebSocket, WebRTC")
Rel(admin_user, admin_app, "Uses", "HTTPS")
Rel(user_mobile, mobile_app, "Uses", "HTTPS, WebSocket, WebRTC")
Rel(web_app, api_server, "API, WebSocket, call signaling, analytics events", "REST, Socket.IO")
Rel(admin_app, api_server, "API", "REST")
Rel(mobile_app, api_server, "API, WebSocket, call signaling, analytics events", "REST, Socket.IO")
Rel(web_app, growthbook, "Feature flags", "HTTPS, optional")
Rel(api_server, postgres, "Reads/Writes", "Prisma")
Rel(api_server, redis, "Cache, Pub/Sub, feed cache")
Rel(api_server, kafka, "Produce/Consume", "KafkaJS")
Rel(api_server, cassandra, "Posts, feed", "cassandra-driver")
Rel(api_server, mongodb, "Comments", "MongoDB driver")
Rel(api_server, elasticsearch, "Search", "Elasticsearch client")
Rel(api_server, file_storage, "Upload/Download")
Rel(api_server, media_gen, "Image/Video/Voice APIs", "HTTP, :3456")
Rel(api_server, ollama, "Chat stream", "HTTP, optional")

SHOW_LEGEND()
@enduml
