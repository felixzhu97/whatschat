@startuml
!global RELATIVE_INCLUDE = 1
!include ../../../c4-lib/C4-PlantUML/C4_Component.puml

title C4 Level 3 - Components: Web Application (Next.js)

Container_Boundary(web_app, "Web Application") {
  Component(pages, "Pages", "Next.js App Router", "Login, Register, Main (feed/Reels/messages), Settings")
  Component(nav_ui, "Left Nav", "React, Emotion", "Instagram-style nav: icons, hover flyout, Home/Reels/Messages/Profile")
  Component(feed_ui, "Feed UI", "React, Emotion", "Stories, feed posts (image/video, click pause/play), create-post entry; center column")
  Component(reels_ui, "Reels UI", "React, Emotion", "Vertical video feed, click pause/play, nav arrows, actions column, follow/caption overlay")
  Component(create_post, "Create Post Flow", "React, Emotion", "Select image/video, crop, caption, sharing, success (View post / Create another / Done)")
  Component(comments_dialog, "Comments Dialog", "React, Emotion", "Post image/video (click pause/play, no control bar), caption, comment list, reply, i18n")
  Component(chat_ui, "Chat UI", "React, Emotion", "DM-style: messages sidebar, chat header, blue bubbles, rounded input, popovers")
  Component(sidebar_ui, "Right Sidebar", "React, Emotion", "User card, suggestions (API), follow")
  Component(i18n_ui, "i18n", "i18next, react-i18next", "Default English; locale in Settings, localStorage")
  Component(call_ui, "Call UI", "React, WebRTC, Emotion", "Voice/video call UI; useCall from @whatschat/im")
  Component(auth_hooks, "Auth Hooks", "Redux Toolkit + React Redux", "Login state, token refresh")
  Component(message_hooks, "Message Hooks", "@whatschat/im + Redux", "useChatsWithLiveMessages, message slices")
  Component(feed_hooks, "Feed Hooks", "React", "useFeed: loadFeed, createPost, entries/pageState")
  Component(ab_feature, "A/B & Feature Flags", "GrowthBook React", "useFeatureIsOn, useAbTest, experiments")
  Component(api_client, "API Client", "Fetch/axios", "REST: feed, posts, comments, auth, chat")
  Component(ws_client, "WebSocket Client", "Socket.IO", "Realtime connection")
  Component(rtc_config, "RTC Config", "web-rtc-config.ts", "createCallManager(createWebRTCConfig())")
  Component(im_pkg, "IM Package", "@whatschat/im", "Chat + RTC logic, re-exports @whatschat/rtc")
  Component(domain_types, "Domain Types", "@whatschat/domain", "User, Message, Chat, Contact, Call")
}

Container_Ext(api_server, "API Server", "NestJS", "Backend API")
Container_Ext(growthbook, "GrowthBook", "A/B & feature flags", "Optional")
Person(user, "Web User", "Uses the app")

Rel(user, pages, "Uses")
Rel(pages, nav_ui, "Renders")
Rel(pages, feed_ui, "Renders")
Rel(pages, reels_ui, "Renders")
Rel(pages, chat_ui, "Renders")
Rel(pages, sidebar_ui, "Renders")
Rel(pages, i18n_ui, "Locale")
Rel(pages, call_ui, "Renders")
Rel(nav_ui, i18n_ui, "t()")
Rel(feed_ui, auth_hooks, "Uses")
Rel(feed_ui, feed_hooks, "Uses")
Rel(feed_ui, create_post, "Opens")
Rel(feed_ui, comments_dialog, "Opens")
Rel(reels_ui, feed_hooks, "Uses")
Rel(reels_ui, auth_hooks, "Uses")
Rel(reels_ui, comments_dialog, "Opens")
Rel(create_post, api_client, "createPost")
Rel(comments_dialog, api_client, "comments API")
Rel(feed_hooks, api_client, "getFeed, createPost")
Rel(chat_ui, message_hooks, "Uses")
Rel(chat_ui, auth_hooks, "Uses")
Rel(chat_ui, ab_feature, "Uses")
Rel(sidebar_ui, i18n_ui, "t()")
Rel(call_ui, auth_hooks, "Uses")
Rel(call_ui, im_pkg, "useCall")
Rel(call_ui, rtc_config, "getWebRTCManager")
Rel(rtc_config, im_pkg, "createCallManager")
Rel(rtc_config, ws_client, "Signaling")
Rel(message_hooks, api_client, "Calls")
Rel(message_hooks, ws_client, "Subscribes")
Rel(ab_feature, growthbook, "Flags, experiments", "HTTPS, optional")
Rel(auth_hooks, api_client, "Calls")
Rel(api_client, api_server, "HTTPS")
Rel(ws_client, api_server, "WebSocket")
Rel(message_hooks, im_pkg, "Uses")
Rel(message_hooks, domain_types, "Uses types")
Rel(chat_ui, im_pkg, "Uses")
Rel(chat_ui, domain_types, "Uses types")

SHOW_LEGEND()
@enduml
