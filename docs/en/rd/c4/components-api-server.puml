@startuml
!global RELATIVE_INCLUDE = 1
!include ../../../c4-lib/C4-PlantUML/C4_Component.puml

title C4 Level 3 - Components: API Server (NestJS)

Container_Boundary(api_server, "API Server") {
  Component(controllers, "REST Controllers", "NestJS", "Auth, Users, Messages, Chats, Groups, Calls, Files, Posts, Comments, Follow, Search, Explore, Admin, Analytics, AI, Image, Video, Voice")
  Component(websocket, "WebSocket Gateway", "Socket.IO", "Realtime messages, presence, typing, call signaling")
  Component(auth_svc, "Auth Service", "NestJS", "Login, JWT, refresh, password")
  Component(user_svc, "User Service", "NestJS", "Profile, search, followers/following (isFollowing)")
  Component(message_svc, "Message Service", "NestJS", "Send, list, reactions")
  Component(chat_svc, "Chat Service", "NestJS", "Chat list, create, participants")
  Component(post_svc, "Post Service", "NestJS", "Create post, get post, list by user; engagement counts; Cassandra")
  Component(feed_svc, "Feed Service", "NestJS", "Feed (own + followed), engagement ranking; Kafka consumer post.created")
  Component(explore_svc, "Explore Service", "NestJS", "Explore stream from Redis cache")
  Component(comment_svc, "Comment Service", "NestJS", "Create, list comments; MongoDB; engagement count")
  Component(follow_svc, "Follow Service", "NestJS", "Follow/unfollow, suggestions from Redis, followers/following lists")
  Component(search_svc, "Search Service", "NestJS", "Users, posts, hashtags; Elasticsearch")
  Component(call_svc, "Call Service", "NestJS", "Call signaling (WebSocket)")
  Component(file_svc, "File Service", "NestJS", "Upload, local storage")
  Component(analytics_svc, "Analytics Service", "NestJS", "Event ingest, overview, event list")
  Component(ai_svc, "AI Service", "NestJS", "Chat stream via @whatschat/llm (Ollama)")
  Component(image_svc, "Image Service", "NestJS", "Prompt refined via Ollama; generate via @whatschat/image-generation (Media Gen or Replicate)")
  Component(video_svc, "Video Service", "NestJS", "Generate via @whatschat/video-generation (Media Gen)")
  Component(voice_svc, "Voice Service", "NestJS", "LLM text + optional translate; TTS via Media Gen (edge-tts)")
  ComponentDb(repo, "Repositories", "Prisma", "Data access, @whatschat/domain types")
  ComponentDb(post_repo, "Post/Feed/Engagement Repos", "Cassandra", "Posts, feed_by_user, likes, saves, counts")
  ComponentDb(comment_repo, "Comment Repo", "MongoDB", "Comments")
}

Container_Ext(web_app, "Web App", "Next.js", "Browser client")
Container_Ext(mobile_app, "Mobile App", "Expo", "Mobile client")
ContainerDb_Ext(postgres, "PostgreSQL", "Database", "Persistent storage")
Container_Ext(redis, "Redis", "Cache", "Session, feed cache, Pub/Sub")
Container_Ext(kafka, "Kafka", "Message Queue", "Offline messages, post.created")
ContainerDb_Ext(cassandra, "Cassandra", "Wide-column", "Posts, feed")
ContainerDb_Ext(mongodb, "MongoDB", "Document", "Comments")
ContainerDb_Ext(elasticsearch, "Elasticsearch", "Search", "Posts, users, hashtags")
Container_Ext(file_storage, "File Storage", "Local", "Files")
Container_Ext(ollama, "Ollama", "LLM", "Chat stream")
Container_Ext(media_gen, "Media Gen Service", "Python", "Image, video, voice, :3456")

Rel(web_app, controllers, "REST, WebSocket")
Rel(mobile_app, controllers, "REST, WebSocket")
Rel(controllers, auth_svc, "Uses")
Rel(controllers, user_svc, "Uses")
Rel(controllers, message_svc, "Uses")
Rel(controllers, chat_svc, "Uses")
Rel(controllers, call_svc, "Uses")
Rel(controllers, file_svc, "Uses")
Rel(controllers, analytics_svc, "Uses")
Rel(controllers, ai_svc, "Uses")
Rel(controllers, image_svc, "Uses")
Rel(controllers, video_svc, "Uses")
Rel(controllers, voice_svc, "Uses")
Rel(controllers, post_svc, "Uses")
Rel(controllers, feed_svc, "Uses")
Rel(controllers, explore_svc, "Uses")
Rel(controllers, comment_svc, "Uses")
Rel(controllers, follow_svc, "Uses")
Rel(controllers, search_svc, "Uses")
Rel(controllers, websocket, "Uses")
Rel(websocket, message_svc, "Uses")
Rel(post_svc, post_repo, "Uses")
Rel(post_svc, kafka, "Produce post.created")
Rel(feed_svc, post_repo, "Uses")
Rel(feed_svc, redis, "Feed cache")
Rel(feed_svc, kafka, "Consume post.created")
Rel(explore_svc, redis, "Explore list")
Rel(comment_svc, comment_repo, "Uses")
Rel(follow_svc, repo, "Uses")
Rel(follow_svc, redis, "Suggestions cache")
Rel(search_svc, elasticsearch, "Query")
Rel(feed_svc, user_svc, "Follow list")
Rel(ai_svc, ollama, "Stream")
Rel(image_svc, ollama, "Refine prompt")
Rel(image_svc, media_gen, "HTTP /image")
Rel(video_svc, media_gen, "HTTP /video")
Rel(voice_svc, ai_svc, "Text, translate")
Rel(voice_svc, media_gen, "HTTP /voice")
Rel(auth_svc, repo, "Uses")
Rel(user_svc, repo, "Uses")
Rel(message_svc, repo, "Uses")
Rel(chat_svc, repo, "Uses")
Rel(call_svc, repo, "Uses")
Rel(file_svc, repo, "Uses")
Rel(analytics_svc, repo, "Uses")
Rel(repo, postgres, "Prisma")
Rel(post_repo, cassandra, "cassandra-driver")
Rel(comment_repo, mongodb, "MongoDB driver")
Rel(auth_svc, redis, "Session")
Rel(websocket, redis, "Pub/Sub")
Rel(websocket, kafka, "Offline queue")
Rel(file_svc, file_storage, "Upload/Download")

SHOW_LEGEND()
@enduml
