@startuml
!global RELATIVE_INCLUDE = 1
!include ../../../c4-lib/C4-PlantUML/C4_Component.puml

title C4 Level 3 - Components: API Server (NestJS)

Container_Boundary(api_server, "API Server") {
  Component(controllers, "REST Controllers", "NestJS", "Auth, Users, Messages, Chats, Groups, Calls, Files, Admin, Analytics, AI, Image, Video")
  Component(websocket, "WebSocket Gateway", "Socket.IO", "Realtime messages, presence, typing, call signaling")
  Component(auth_svc, "Auth Service", "NestJS", "Login, JWT, refresh, password")
  Component(user_svc, "User Service", "NestJS", "Profile, search")
  Component(message_svc, "Message Service", "NestJS", "Send, list, reactions")
  Component(chat_svc, "Chat Service", "NestJS", "Chat list, create, participants")
  Component(call_svc, "Call Service", "NestJS", "Call signaling (WebSocket)")
  Component(file_svc, "File Service", "NestJS", "Upload, local storage")
  Component(analytics_svc, "Analytics Service", "NestJS", "Event ingest, overview, event list")
  Component(ai_svc, "AI Service", "NestJS", "Chat stream via @whatschat/llm (Ollama)")
  Component(image_svc, "Image Service", "NestJS", "Prompt refined via Ollama; generate via @whatschat/image-generation (HTTP or Replicate)")
  Component(video_svc, "Video Service", "NestJS", "Generate via @whatschat/video-generation (HTTP)")
  ComponentDb(repo, "Repositories", "Prisma", "Data access, @whatschat/domain types")
}

Container_Ext(web_app, "Web App", "Next.js", "Browser client")
Container_Ext(mobile_app, "Mobile App", "Expo", "Mobile client")
ContainerDb_Ext(postgres, "PostgreSQL", "Database", "Persistent storage")
Container_Ext(redis, "Redis", "Cache", "Session, Pub/Sub")
Container_Ext(kafka, "Kafka", "Message Queue", "Offline messages")
Container_Ext(file_storage, "File Storage", "Local", "Files")
Container_Ext(ollama, "Ollama", "LLM", "Chat stream")
Container_Ext(image_gen, "Image Gen Service", "Python", ":3457")
Container_Ext(video_gen, "Video Gen Service", "Python", ":3456")

Rel(web_app, controllers, "REST, WebSocket")
Rel(mobile_app, controllers, "REST, WebSocket")
Rel(controllers, auth_svc, "Uses")
Rel(controllers, user_svc, "Uses")
Rel(controllers, message_svc, "Uses")
Rel(controllers, chat_svc, "Uses")
Rel(controllers, call_svc, "Uses")
Rel(controllers, file_svc, "Uses")
Rel(controllers, analytics_svc, "Uses")
Rel(controllers, ai_svc, "Uses")
Rel(controllers, image_svc, "Uses")
Rel(controllers, video_svc, "Uses")
Rel(controllers, websocket, "Uses")
Rel(websocket, message_svc, "Uses")
Rel(ai_svc, ollama, "Stream")
Rel(image_svc, ollama, "Refine prompt")
Rel(image_svc, image_gen, "HTTP job")
Rel(video_svc, video_gen, "HTTP job")
Rel(auth_svc, repo, "Uses")
Rel(user_svc, repo, "Uses")
Rel(message_svc, repo, "Uses")
Rel(chat_svc, repo, "Uses")
Rel(call_svc, repo, "Uses")
Rel(file_svc, repo, "Uses")
Rel(analytics_svc, repo, "Uses")
Rel(repo, postgres, "Prisma")
Rel(auth_svc, redis, "Session")
Rel(websocket, redis, "Pub/Sub")
Rel(websocket, kafka, "Offline queue")
Rel(file_svc, file_storage, "Upload/Download")

SHOW_LEGEND()
@enduml
