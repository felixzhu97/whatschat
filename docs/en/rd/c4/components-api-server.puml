@startuml
!global RELATIVE_INCLUDE = 1
!include ../../../c4-lib/C4-PlantUML/C4_Component.puml

title C4 Level 3 - Components: API Server (NestJS)

Container_Boundary(api_server, "API Server") {
  Component(controllers, "REST Controllers", "NestJS", "Auth, Users, Messages, Chats, Groups, Calls, Files, Posts, Comments, Follow, Search, Explore, Notifications, Admin, Analytics, Ads Admin, AI, Image, Video, Voice")
  Component(graphql_api, "GraphQL API", "Apollo Server", "POST /api/v1/graphql; Query feed(limit, pageState) with organic + sponsored entries; FeedEntry.post via DataLoader + PostService/AdCreativeService; JWT guard; REST unchanged")
  Component(websocket, "WebSocket Gateway", "Socket.IO", "Realtime messages, presence, typing, call signaling, notification:new to recipient")
  Component(auth_svc, "Auth Service", "NestJS", "Login, JWT, refresh, password")
  Component(user_svc, "User Service", "NestJS", "Profile, search, followers/following (isFollowing)")
  Component(message_svc, "Message Service", "NestJS", "Send, list, reactions")
  Component(chat_svc, "Chat Service", "NestJS", "Chat list, create, participants")
  Component(post_svc, "Post Service", "NestJS", "Create post (mediaUrls + coverUrl); sync Vision moderation on create; get post (respects hidden/reject); list by user; Cassandra posts/post_by_id")
  Component(feed_svc, "Feed Service", "NestJS", "Feed (own + followed), engagement ranking; mixes ad candidates from AdService; Kafka consumer post.created, Vision updates ES moderationStatus")
  Component(explore_svc, "Explore Service", "NestJS", "Explore stream from Redis cache; mixes ad candidates from AdService")
  Component(comment_svc, "Comment Service", "NestJS", "Create, list comments; MongoDB; engagement count")
  Component(follow_svc, "Follow Service", "NestJS", "Follow/unfollow, suggestions from Redis, followers/following lists")
  Component(search_svc, "Search Service", "NestJS", "Users, posts, hashtags; cursor pagination, highlight, rate limit; Elasticsearch")
  Component(notification_svc, "Notification Service", "NestJS", "Activity notifications (like/comment); MongoDB; GET cursor, PATCH read, POST read-all; emit notification:new")
  Component(call_svc, "Call Service", "NestJS", "Call signaling (WebSocket)")
  Component(file_svc, "File Service", "NestJS", "Upload, local storage")
  Component(analytics_svc, "Analytics Service", "NestJS", "Event ingest, overview, event list, ad metrics aggregation from analytics_events")
  Component(ai_svc, "AI Service", "NestJS", "Chat stream via @whatschat/llm (Ollama)")
  Component(image_svc, "Image Service", "NestJS", "Prompt refined via Ollama; generate via @whatschat/image-generation (Media Gen or Replicate)")
  Component(video_svc, "Video Service", "NestJS", "Generate via @whatschat/video-generation (Media Gen)")
  Component(voice_svc, "Voice Service", "NestJS", "LLM text + optional translate; TTS via Media Gen (edge-tts)")
  Component(admin_svc, "Admin Service", "NestJS", "Posts list, content safety stats; recheck moderation, hide, batch delete/hide; calls Vision")
  Component(ad_admin_svc, "Ads Admin Service", "NestJS", "CRUD for AdAccount/AdCampaign/AdGroup/AdCreative; used by Admin dashboard")
  Component(ad_svc, "Ad Service", "NestJS", "Ad candidates selection, delivery recording into AdSpend")
  Component(ad_targeting_svc, "Ad Targeting Service", "NestJS", "Match AdGroup targeting JSON against user profile/context")
  Component(ad_pacing_svc, "Ad Pacing Service", "NestJS", "Budget control via AdSpend aggregation (daily/total)")
  Component(ad_creative_svc, "Ad Creative Service", "NestJS", "Load AdCreative for GraphQL FeedEntry.post when sponsored")
  ComponentDb(repo, "Repositories", "Prisma", "Data access, @whatschat/domain types, ad entities, analytics_events")
  ComponentDb(post_repo, "Post/Feed/Engagement Repos", "Cassandra", "Posts, feed_by_user, likes, saves, counts")
  ComponentDb(comment_repo, "Comment Repo", "MongoDB", "Comments")
  ComponentDb(notification_repo, "Notification Repo", "MongoDB", "notifications collection")
}

Container_Ext(web_app, "Web App", "Next.js", "Browser client")
Container_Ext(mobile_app, "Mobile App", "Expo", "Mobile client")
ContainerDb_Ext(postgres, "PostgreSQL", "Database", "Persistent storage")
Container_Ext(redis, "Redis", "Cache", "Session, feed cache, Pub/Sub")
Container_Ext(kafka, "Kafka", "Message Queue", "Offline messages, post.created")
ContainerDb_Ext(cassandra, "Cassandra", "Wide-column", "Posts, feed")
ContainerDb_Ext(mongodb, "MongoDB", "Document", "Comments")
ContainerDb_Ext(elasticsearch, "Elasticsearch", "Search", "Posts, users, hashtags, moderation")
Container_Ext(file_storage, "File Storage", "Local", "Files")
Container_Ext(ollama, "Ollama", "LLM", "Chat stream")
Container_Ext(media_gen, "Media Gen Service", "Python", "Image, video, voice, :3456")
Container_Ext(vision_svc, "Vision Service", "Python, FastAPI, NudeNet, ResNet50", "Tag suggestion, image/video moderation, :8001")

Rel(web_app, controllers, "REST, WebSocket")
Rel(web_app, graphql_api, "GraphQL, JWT")
Rel(mobile_app, controllers, "REST, WebSocket")
Rel(mobile_app, graphql_api, "GraphQL, JWT")
Rel(graphql_api, feed_svc, "Uses")
Rel(graphql_api, post_svc, "Uses")
Rel(graphql_api, ad_creative_svc, "Uses")
Rel(controllers, auth_svc, "Uses")
Rel(controllers, user_svc, "Uses")
Rel(controllers, message_svc, "Uses")
Rel(controllers, chat_svc, "Uses")
Rel(controllers, call_svc, "Uses")
Rel(controllers, file_svc, "Uses")
Rel(controllers, analytics_svc, "Uses")
Rel(controllers, ai_svc, "Uses")
Rel(controllers, image_svc, "Uses")
Rel(controllers, video_svc, "Uses")
Rel(controllers, voice_svc, "Uses")
Rel(controllers, post_svc, "Uses")
Rel(controllers, admin_svc, "Uses")
Rel(controllers, ad_admin_svc, "Uses")
Rel(controllers, feed_svc, "Uses")
Rel(controllers, explore_svc, "Uses")
Rel(controllers, ad_svc, "Uses")
Rel(controllers, comment_svc, "Uses")
Rel(controllers, follow_svc, "Uses")
Rel(controllers, search_svc, "Uses")
Rel(controllers, notification_svc, "Uses")
Rel(controllers, websocket, "Uses")
Rel(websocket, message_svc, "Uses")
Rel(post_svc, post_repo, "Uses")
Rel(post_svc, kafka, "Produce post.created")
Rel(feed_svc, post_repo, "Uses")
Rel(feed_svc, redis, "Feed cache")
Rel(feed_svc, kafka, "Consume post.created")
Rel(feed_svc, ad_svc, "Requests ad candidates")
Rel(feed_svc, ad_targeting_svc, "Filters by targeting")
Rel(feed_svc, ad_pacing_svc, "Checks budgets")
Rel(explore_svc, redis, "Explore list")
Rel(explore_svc, ad_svc, "Requests ad candidates")
Rel(explore_svc, ad_targeting_svc, "Filters by targeting")
Rel(explore_svc, ad_pacing_svc, "Checks budgets")
Rel(comment_svc, comment_repo, "Uses")
Rel(notification_svc, notification_repo, "Uses")
Rel(notification_svc, websocket, "emit notification:new")
Rel(follow_svc, repo, "Uses")
Rel(follow_svc, redis, "Suggestions cache")
Rel(search_svc, elasticsearch, "Query")
Rel(feed_svc, user_svc, "Follow list")
Rel(ai_svc, ollama, "Stream")
Rel(image_svc, ollama, "Refine prompt")
Rel(image_svc, media_gen, "HTTP /image")
Rel(video_svc, media_gen, "HTTP /video")
Rel(voice_svc, ai_svc, "Text, translate")
Rel(voice_svc, media_gen, "HTTP /voice")
Rel(controllers, vision_svc, "Suggest tags, moderate", "HTTP :8001")
Rel(post_svc, vision_svc, "Moderate on create", "HTTP :8001")
Rel(admin_svc, vision_svc, "Recheck moderation", "HTTP :8001")
Rel(auth_svc, repo, "Uses")
Rel(user_svc, repo, "Uses")
Rel(message_svc, repo, "Uses")
Rel(chat_svc, repo, "Uses")
Rel(call_svc, repo, "Uses")
Rel(file_svc, repo, "Uses")
Rel(analytics_svc, repo, "Uses")
Rel(admin_svc, repo, "Uses")
Rel(admin_svc, post_repo, "Uses")
Rel(admin_svc, elasticsearch, "Update moderation, hidden")
Rel(ad_admin_svc, repo, "Uses (AdAccount/AdCampaign/AdGroup/AdCreative/AdSpend)")
Rel(ad_svc, repo, "Reads ad entities, writes AdSpend")
Rel(ad_pacing_svc, repo, "Aggregates AdSpend + budgets")
Rel(analytics_svc, repo, "Reads analytics_events for ad metrics")
Rel(repo, postgres, "Prisma")
Rel(post_repo, cassandra, "cassandra-driver")
Rel(comment_repo, mongodb, "MongoDB driver")
Rel(notification_repo, mongodb, "MongoDB driver")
Rel(auth_svc, redis, "Session")
Rel(websocket, redis, "Pub/Sub")
Rel(websocket, kafka, "Offline queue")
Rel(file_svc, file_storage, "Upload/Download")

SHOW_LEGEND()
@enduml
