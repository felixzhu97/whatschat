@startuml
!global RELATIVE_INCLUDE = 1
!include ../../../c4-lib/C4-PlantUML/C4_Context.puml

title C4 Level 1 - System Context: WhatsChat

Person(user_web, "Web User", "Uses chat, calls, and contacts via browser")
Person(user_mobile, "Mobile User", "Uses chat, calls, and contacts via mobile app")
Person(admin_user, "Admin User", "Manages users, content, ops via admin dashboard")

System_Boundary(whatschat, "WhatsChat") {
  System(whatschat_sys, "WhatsChat", "Instant messaging: chat, voice/video calls, file sharing, feed & posts, comments, follow, recommendations & explore, contacts, groups")
}

System_Ext(email, "Email Service", "Sends transactional email (e.g. SMTP/SES)")
System_Ext(push, "Push Service", "Push notifications (FCM/APNs)")
System_Ext(storage, "File Storage", "Local file storage")
System_Ext(webrtc, "STUN/TURN", "WebRTC NAT traversal")
System_Ext(growthbook, "GrowthBook", "A/B testing and feature flags (optional)")

Rel(user_web, whatschat_sys, "Uses", "HTTPS, WebSocket, WebRTC")
Rel(user_mobile, whatschat_sys, "Uses", "HTTPS, WebSocket, WebRTC")
Rel(admin_user, whatschat_sys, "Manages", "HTTPS")
Rel(whatschat_sys, email, "Sends email")
Rel(whatschat_sys, push, "Sends push")
Rel(whatschat_sys, storage, "Stores/retrieves files")
Rel(whatschat_sys, webrtc, "Media relay")
Rel(whatschat_sys, growthbook, "Feature flags, experiments", "HTTPS")

SHOW_LEGEND()
@enduml
