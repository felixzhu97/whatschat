@startuml
!global RELATIVE_INCLUDE = 1
!include ../../../c4-lib/C4-PlantUML/C4_Component.puml

title C4 Level 3 - Components: Admin Application (Next.js)

Container_Boundary(admin_app, "Admin Application") {
  Component(pages, "Pages", "Next.js App Router", "Dashboard, Users, Content Safety, Ops Monitor, Analytics, Ads & Promotions (ad manager, promoted posts, performance), Shopping & Commerce (store, product tags, order tracking), System Config, Permission & Audit")
  Component(data_grid, "DataGrid", "AG Grid React", "Tables for users, groups; sortable, filterable")
  Component(charts, "Charts", "Recharts", "Bar, Line, Pie; dashboard KPIs, user growth, platform distribution")
  Component(auth_provider, "Auth Provider", "React Context", "Admin login state, JWT, logout")
  Component(theme_provider, "Theme Provider", "React Context + localStorage", "Light/dark theme")
  Component(i18n, "i18n", "i18next, react-i18next", "en/zh locales")
  Component(api_client, "API Client", "Fetch", "REST calls to Admin API (including ads and commerce endpoints)")
}

Container_Ext(api_server, "API Server", "NestJS", "Admin REST API")
Person(admin, "Admin User", "Manages platform")

Rel(admin, pages, "Uses")
Rel(pages, data_grid, "Renders")
Rel(pages, charts, "Renders")
Rel(pages, auth_provider, "Uses")
Rel(pages, theme_provider, "Uses")
Rel(pages, i18n, "Uses")
Rel(data_grid, api_client, "Loads data")
Rel(charts, api_client, "Loads stats")
Rel(auth_provider, api_client, "Auth headers")
Rel(api_client, api_server, "HTTPS")

SHOW_LEGEND()
@enduml
