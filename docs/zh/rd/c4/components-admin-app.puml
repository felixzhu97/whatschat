@startuml
!global RELATIVE_INCLUDE = 1
!include ../../../c4-lib/C4-PlantUML/C4_Component.puml

title C4 Level 3 - 组件：管理端应用（Next.js）

Container_Boundary(admin_app, "管理端应用") {
  Component(pages, "页面", "Next.js App Router", "仪表盘、用户、内容安全、运营监控、业务、分析、系统配置、权限与审计")
  Component(data_grid, "数据表格", "AG Grid React", "用户、群组表格；可排序、可筛选")
  Component(charts, "图表", "Recharts", "柱状、折线、饼图；仪表盘 KPI、用户增长、平台分布")
  Component(auth_provider, "认证 Provider", "React Context", "管理端登录状态、JWT、登出")
  Component(theme_provider, "主题 Provider", "React Context + localStorage", "浅色/深色主题")
  Component(i18n, "i18n", "i18next、react-i18next", "中英语言包")
  Component(api_client, "API 客户端", "Fetch", "REST 调用管理端 API")
}

Container_Ext(api_server, "API 服务", "NestJS", "管理端 REST API")
Person(admin, "管理员", "管理平台")

Rel(admin, pages, "使用")
Rel(pages, data_grid, "渲染")
Rel(pages, charts, "渲染")
Rel(pages, auth_provider, "使用")
Rel(pages, theme_provider, "使用")
Rel(pages, i18n, "使用")
Rel(data_grid, api_client, "加载数据")
Rel(charts, api_client, "加载统计")
Rel(auth_provider, api_client, "认证头")
Rel(api_client, api_server, "HTTPS")

SHOW_LEGEND()
@enduml
