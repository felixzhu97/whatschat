@startuml
!global RELATIVE_INCLUDE = 1
!include ../../../c4-lib/C4-PlantUML/C4_Component.puml

title C4 Level 3 - 组件：Web 应用（Next.js）

Container_Boundary(web_app, "Web 应用") {
  Component(pages, "页面", "Next.js App Router", "登录、注册、主站（信息流/Reels/消息）、设置")
  Component(nav_ui, "左侧导航", "React、Emotion", "首页、Reels、消息、搜索、探索、通知、个人页、发帖")
  Component(search_ui, "全局搜索页", "React、Emotion", "搜索框防抖、Tab 全部/帖子/用户/话题、结果高亮、加载更多（游标）、话题建议下拉；i18n")
  Component(search_hooks, "搜索 Hooks", "React", "useGlobalSearch：防抖、主搜与话题建议、游标分页")
  Component(feed_ui, "信息流 UI", "React、Emotion", "故事、信息流帖子（图片/视频、点赞/收藏、计数、暂停/播放）、发帖；中间栏")
  Component(reels_ui, "Reels UI", "React、Emotion", "竖屏视频流、点赞/收藏、暂停/播放、操作栏、关注/标题叠加")
  Component(explore_ui, "探索 UI", "React、Emotion", "探索 API + getPost；网格最大 963px 居中；视频封面 coverUrl；点赞/收藏、评论弹窗")
  Component(profile_ui, "个人页 UI", "React、Emotion", "个人网格（视频用 coverUrl 作封面）、粉丝/关注、编辑资料、发帖")
  Component(create_post, "发帖流程", "React、Emotion", "选图/视频、裁剪、视频选帧封面；createPost 单独传 coverUrl；不写进 mediaUrls")
  Component(comments_dialog, "评论弹窗", "React、Emotion", "帖子图片/视频（点击暂停/播放）、标题、评论列表、回复、i18n")
  Component(follow_list_modal, "关注列表弹窗", "React、Emotion", "粉丝/关注列表、搜索、无限滚动、isFollowing、关注/取关")
  Component(chat_ui, "聊天 UI", "React、Emotion", "私信风格：消息侧栏、聊天头、蓝色气泡、圆角输入、弹出层")
  Component(sidebar_ui, "右侧栏", "React、Emotion", "用户卡片、推荐（API）、关注")
  Component(i18n_ui, "i18n", "i18next、react-i18next", "默认英语；设置在语言、localStorage")
  Component(call_ui, "通话 UI", "React、WebRTC、Emotion", "音视频通话 UI；@whatschat/im 的 useCall")
  Component(auth_hooks, "认证 Hooks", "Redux Toolkit + React Redux", "登录状态、令牌刷新")
  Component(message_hooks, "消息 Hooks", "@whatschat/im + Redux", "useChatsWithLiveMessages、消息切片")
  Component(notifications_ui, "通知抽屉", "React、Emotion、Radix Sheet", "左侧无遮罩；已读；WS 合并")
  Component(search_drawer, "搜索抽屉", "React、Emotion", "左侧打开全局搜索")
  Component(feed_hooks, "信息流 Hooks", "React", "useFeed、useExplore、createPost(...,coverUrl)、mapDetailToFeedPost")
  Component(ab_feature, "A/B 与功能开关", "GrowthBook React", "useFeatureIsOn、useAbTest、实验")
  Component(api_client, "API 客户端", "Fetch/axios", "REST：信息流、帖子、评论、认证、聊天、搜索（游标）")
  Component(ws_client, "WebSocket 客户端", "Socket.IO", "实时连接")
  Component(rtc_config, "RTC 配置", "web-rtc-config.ts", "createCallManager(createWebRTCConfig())")
  Component(im_pkg, "IM 包", "@whatschat/im", "聊天 + RTC 逻辑，重导出 @whatschat/rtc")
  Component(domain_types, "领域类型", "@whatschat/domain", "User、Message、Chat、Contact、Call")
}

Container_Ext(api_server, "API 服务", "NestJS", "后端 API")
Container_Ext(growthbook, "GrowthBook", "A/B 与功能开关", "可选")
Person(user, "Web 用户", "使用应用")

Rel(user, pages, "使用")
Rel(pages, nav_ui, "渲染")
Rel(pages, feed_ui, "渲染")
Rel(pages, reels_ui, "渲染")
Rel(pages, explore_ui, "渲染")
Rel(pages, search_ui, "渲染")
Rel(nav_ui, search_ui, "进入")
Rel(nav_ui, notifications_ui, "打开")
Rel(nav_ui, search_drawer, "打开")
Rel(search_ui, search_hooks, "使用")
Rel(search_ui, i18n_ui, "t()")
Rel(search_hooks, api_client, "search")
Rel(pages, profile_ui, "渲染")
Rel(pages, chat_ui, "渲染")
Rel(pages, sidebar_ui, "渲染")
Rel(pages, i18n_ui, "语言")
Rel(pages, call_ui, "渲染")
Rel(nav_ui, i18n_ui, "t()")
Rel(feed_ui, auth_hooks, "使用")
Rel(feed_ui, feed_hooks, "使用")
Rel(feed_ui, create_post, "打开")
Rel(feed_ui, comments_dialog, "打开")
Rel(profile_ui, feed_hooks, "使用")
Rel(profile_ui, follow_list_modal, "打开")
Rel(reels_ui, feed_hooks, "使用")
Rel(reels_ui, auth_hooks, "使用")
Rel(reels_ui, comments_dialog, "打开")
Rel(explore_ui, feed_hooks, "使用")
Rel(explore_ui, comments_dialog, "打开")
Rel(create_post, api_client, "createPost + coverUrl")
Rel(notifications_ui, ws_client, "notification:new")
Rel(comments_dialog, api_client, "评论 API")
Rel(follow_list_modal, api_client, "getFollowers、getFollowing、follow、unfollow")
Rel(feed_hooks, api_client, "getFeed、getExplore、createPost、like、save、getSuggestions")
Rel(chat_ui, message_hooks, "使用")
Rel(chat_ui, auth_hooks, "使用")
Rel(chat_ui, ab_feature, "使用")
Rel(sidebar_ui, i18n_ui, "t()")
Rel(call_ui, auth_hooks, "使用")
Rel(call_ui, im_pkg, "useCall")
Rel(call_ui, rtc_config, "getWebRTCManager")
Rel(rtc_config, im_pkg, "createCallManager")
Rel(rtc_config, ws_client, "信令")
Rel(message_hooks, api_client, "调用")
Rel(message_hooks, ws_client, "订阅")
Rel(ab_feature, growthbook, "开关、实验", "HTTPS，可选")
Rel(auth_hooks, api_client, "调用")
Rel(api_client, api_server, "HTTPS")
Rel(ws_client, api_server, "WebSocket")
Rel(message_hooks, im_pkg, "使用")
Rel(message_hooks, domain_types, "使用类型")
Rel(chat_ui, im_pkg, "使用")
Rel(chat_ui, domain_types, "使用类型")

SHOW_LEGEND()
@enduml
