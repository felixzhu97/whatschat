@startuml
!global RELATIVE_INCLUDE = 1
!include ../../../c4-lib/C4-PlantUML/C4_Component.puml

title C4 Level 3 - 组件：移动端应用（Expo）

Container_Boundary(mobile_app, "移动端应用") {
  Component(screens, "屏幕", "Expo Router", "首页信息流（类 Instagram）、故事（Stories）、聊天列表、聊天详情、设置、通话、登录")
  Component(chat_ui, "聊天 UI", "React Native、Emotion", "消息列表、输入、气泡、标签")
  Component(feed_ui, "信息流与故事 UI", "React Native、Emotion", "Instagram 风格顶部栏、横向故事条、纵向多图/视频信息流，下拉刷新与无限滚动")
  Component(call_ui, "通话 UI", "React Native、WebRTC", "音视频通话 UI；@whatschat/im 的 useCall")
  Component(settings_ui, "设置 UI", "React Native、Emotion", "iOS 风格分组卡片、主题、语言、资料")
  Component(auth_hooks, "认证 Hooks", "Redux Toolkit + React Redux", "登录状态、令牌刷新")
  Component(message_hooks, "消息 Hooks", "@whatschat/im + Redux", "useChatsWithLiveMessages、消息切片")
  Component(feed_hooks, "信息流 Hooks", "React Hooks + GraphQL", "useMobileFeed/useMobileStories；带防抖的翻页、下拉刷新，与 Web 复用 GraphQL feed 查询")
  Component(i18n, "i18n", "i18next、react-i18next", "中英语言包、语言选择")
  Component(theme, "主题", "Context + AsyncStorage", "浅色/深色/系统、主题感知布局")
  Component(api_client, "API 客户端", "Fetch/axios + GraphQL", "REST/GraphQL 调用 API 服务")
  Component(ws_client, "WebSocket 客户端", "Socket.IO", "实时连接")
  Component(video_player, "视频播放器", "expo-video", "首页信息流中视频按可见性自动播放/暂停，静音切换；同屏仅一个活跃播放器")
  Component(analytics_client, "分析埋点客户端", "@whatschat/analytics", "上报信息流浏览/点赞/收藏、视频播放/完成、广告曝光/点击，保证与 Web 一致")
  Component(rtc_config, "RTC 配置", "callManagerLoader + mobile-rtc-config", "createCallManager(createMobileRTCConfig())、setSocket")
  Component(im_pkg, "IM 包", "@whatschat/im", "聊天 + RTC 逻辑，重导出 @whatschat/rtc")
  Component(domain_types, "领域类型", "@whatschat/domain", "User、Message、Chat、Contact、Call")
}

Container_Ext(api_server, "API 服务", "NestJS", "后端 API")
Person(user, "移动端用户", "使用应用")

Rel(user, screens, "使用")
Rel(screens, chat_ui, "渲染")
Rel(screens, feed_ui, "渲染")
Rel(screens, call_ui, "渲染")
Rel(screens, settings_ui, "渲染")
Rel(chat_ui, message_hooks, "使用")
Rel(chat_ui, auth_hooks, "使用")
Rel(chat_ui, i18n, "使用")
Rel(chat_ui, theme, "使用")
Rel(feed_ui, feed_hooks, "使用")
Rel(feed_ui, video_player, "渲染视频")
Rel(feed_ui, analytics_client, "上报信息流/视频/广告事件")
Rel(feed_hooks, api_client, "GraphQL 拉取 feed + stories")
Rel(settings_ui, i18n, "使用")
Rel(settings_ui, theme, "使用")
Rel(call_ui, auth_hooks, "使用")
Rel(call_ui, im_pkg, "useCall")
Rel(call_ui, rtc_config, "getCallManager")
Rel(rtc_config, im_pkg, "createCallManager")
Rel(rtc_config, ws_client, "通过 setSocket 信令")
Rel(message_hooks, api_client, "调用")
Rel(message_hooks, ws_client, "订阅")
Rel(message_hooks, im_pkg, "使用")
Rel(message_hooks, domain_types, "使用类型")
Rel(chat_ui, im_pkg, "使用")
Rel(chat_ui, domain_types, "使用类型")
Rel(auth_hooks, api_client, "调用")
Rel(analytics_client, api_client, "发送 analytics_events")
Rel(api_client, api_server, "HTTPS")
Rel(ws_client, api_server, "WebSocket")

SHOW_LEGEND()
@enduml
