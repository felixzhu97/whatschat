@startuml
!global RELATIVE_INCLUDE = 1
!include ../../../c4-lib/C4-PlantUML/C4_Component.puml

title C4 Level 3 - 组件：API 服务（NestJS）

Container_Boundary(api_server, "API 服务") {
  Component(controllers, "REST 控制器", "NestJS", "认证、用户、消息、聊天、群组、通话、文件、帖子、评论、关注、搜索、探索、通知、管理、分析、AI、图片、视频、语音")
  Component(graphql_api, "GraphQL API", "Apollo Server", "POST /api/v1/graphql；Query feed(limit, pageState)；FeedEntry.post 经 DataLoader + PostService；JWT 守卫；REST 保留")
  Component(websocket, "WebSocket 网关", "Socket.IO", "实时消息、在线状态、输入状态、通话信令、notification:new 推送给被通知用户")
  Component(auth_svc, "认证服务", "NestJS", "登录、JWT、刷新、密码")
  Component(user_svc, "用户服务", "NestJS", "资料、搜索、粉丝/关注（isFollowing）")
  Component(message_svc, "消息服务", "NestJS", "发送、列表、反应")
  Component(chat_svc, "聊天服务", "NestJS", "聊天列表、创建、参与者")
  Component(post_svc, "帖子服务", "NestJS", "发帖（mediaUrls + 可选 coverUrl）、获取帖子、按用户列表；互动计数；Cassandra cover_url")
  Component(feed_svc, "信息流服务", "NestJS", "信息流（本人+关注）、互动排序；Kafka 消费 post.created")
  Component(explore_svc, "探索服务", "NestJS", "探索流来自 Redis 缓存")
  Component(comment_svc, "评论服务", "NestJS", "创建、列表评论；MongoDB；互动计数")
  Component(follow_svc, "关注服务", "NestJS", "关注/取关、推荐来自 Redis、粉丝/关注列表")
  Component(search_svc, "搜索服务", "NestJS", "用户、帖子、话题；游标分页、高亮、限流；ES 不可用时用户回退 Prisma；Elasticsearch")
  Component(notification_svc, "通知服务", "NestJS", "点赞/评论活动通知；MongoDB；游标已读；取消赞/删评删除；WS 推送")
  Component(call_svc, "通话服务", "NestJS", "通话信令（WebSocket）")
  Component(file_svc, "文件服务", "NestJS", "上传、本地存储")
  Component(analytics_svc, "分析服务", "NestJS", "事件接入、概览、事件列表")
  Component(ai_svc, "AI 服务", "NestJS", "通过 @whatschat/llm 聊天流（Ollama）")
  Component(image_svc, "图片服务", "NestJS", "通过 Ollama 优化提示；通过 @whatschat/image-generation 生成（Media Gen 或 Replicate）")
  Component(video_svc, "视频服务", "NestJS", "通过 @whatschat/video-generation 生成（Media Gen）")
  Component(voice_svc, "语音服务", "NestJS", "LLM 文本 + 可选翻译；TTS 通过 Media Gen（edge-tts）")
  ComponentDb(repo, "仓储", "Prisma", "数据访问、@whatschat/domain 类型")
  ComponentDb(post_repo, "帖子/信息流/互动仓储", "Cassandra", "帖子、feed_by_user、点赞、收藏、计数")
  ComponentDb(comment_repo, "评论仓储", "MongoDB", "评论")
  ComponentDb(notification_repo, "通知仓储", "MongoDB", "notifications 集合")
}

Container_Ext(web_app, "Web 应用", "Next.js", "浏览器客户端")
Container_Ext(mobile_app, "移动端应用", "Expo", "移动端客户端")
ContainerDb_Ext(postgres, "PostgreSQL", "数据库", "持久化存储")
Container_Ext(redis, "Redis", "缓存", "会话、信息流缓存、Pub/Sub")
Container_Ext(kafka, "Kafka", "消息队列", "离线消息、post.created")
ContainerDb_Ext(cassandra, "Cassandra", "宽表", "帖子、信息流")
ContainerDb_Ext(mongodb, "MongoDB", "文档", "评论")
ContainerDb_Ext(elasticsearch, "Elasticsearch", "搜索", "帖子、用户、话题")
Container_Ext(file_storage, "文件存储", "本地", "文件")
Container_Ext(ollama, "Ollama", "LLM", "聊天流")
Container_Ext(media_gen, "媒体生成服务", "Python", "图片、视频、语音，:3456")

Rel(web_app, controllers, "REST、WebSocket")
Rel(web_app, graphql_api, "GraphQL、JWT")
Rel(mobile_app, controllers, "REST、WebSocket")
Rel(mobile_app, graphql_api, "GraphQL、JWT")
Rel(graphql_api, feed_svc, "使用")
Rel(graphql_api, post_svc, "使用")
Rel(controllers, auth_svc, "使用")
Rel(controllers, user_svc, "使用")
Rel(controllers, message_svc, "使用")
Rel(controllers, chat_svc, "使用")
Rel(controllers, call_svc, "使用")
Rel(controllers, file_svc, "使用")
Rel(controllers, analytics_svc, "使用")
Rel(controllers, ai_svc, "使用")
Rel(controllers, image_svc, "使用")
Rel(controllers, video_svc, "使用")
Rel(controllers, voice_svc, "使用")
Rel(controllers, post_svc, "使用")
Rel(controllers, feed_svc, "使用")
Rel(controllers, explore_svc, "使用")
Rel(controllers, comment_svc, "使用")
Rel(controllers, follow_svc, "使用")
Rel(controllers, search_svc, "使用")
Rel(controllers, notification_svc, "使用")
Rel(controllers, websocket, "使用")
Rel(websocket, message_svc, "使用")
Rel(post_svc, post_repo, "使用")
Rel(post_svc, kafka, "生产 post.created")
Rel(feed_svc, post_repo, "使用")
Rel(feed_svc, redis, "信息流缓存")
Rel(feed_svc, kafka, "消费 post.created")
Rel(explore_svc, redis, "探索列表")
Rel(comment_svc, comment_repo, "使用")
Rel(notification_svc, notification_repo, "使用")
Rel(notification_svc, websocket, "emit notification:new")
Rel(follow_svc, repo, "使用")
Rel(follow_svc, redis, "推荐缓存")
Rel(search_svc, elasticsearch, "查询")
Rel(feed_svc, user_svc, "关注列表")
Rel(ai_svc, ollama, "流式")
Rel(image_svc, ollama, "优化提示")
Rel(image_svc, media_gen, "HTTP /image")
Rel(video_svc, media_gen, "HTTP /video")
Rel(voice_svc, ai_svc, "文本、翻译")
Rel(voice_svc, media_gen, "HTTP /voice")
Rel(auth_svc, repo, "使用")
Rel(user_svc, repo, "使用")
Rel(message_svc, repo, "使用")
Rel(chat_svc, repo, "使用")
Rel(call_svc, repo, "使用")
Rel(file_svc, repo, "使用")
Rel(analytics_svc, repo, "使用")
Rel(repo, postgres, "Prisma")
Rel(post_repo, cassandra, "cassandra-driver")
Rel(comment_repo, mongodb, "MongoDB driver")
Rel(notification_repo, mongodb, "MongoDB driver")
Rel(auth_svc, redis, "会话")
Rel(websocket, redis, "Pub/Sub")
Rel(websocket, kafka, "离线队列")
Rel(file_svc, file_storage, "上传/下载")

SHOW_LEGEND()
@enduml
