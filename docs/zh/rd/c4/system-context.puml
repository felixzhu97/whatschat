@startuml
!global RELATIVE_INCLUDE = 1
!include ../../../c4-lib/C4-PlantUML/C4_Context.puml

title C4 Level 1 - 系统上下文：WhatsChat

Person(user_web, "Web 用户", "通过浏览器使用聊天、通话与联系人")
Person(user_mobile, "移动端用户", "通过移动应用使用聊天、通话与联系人")
Person(admin_user, "管理员", "通过管理后台管理用户、内容与运营")

System_Boundary(whatschat, "WhatsChat") {
  System(whatschat_sys, "WhatsChat", "即时通讯：聊天、音视频通话、文件分享、信息流与帖子、评论、关注、推荐与探索、内容审核、联系人、群组")
}

System_Ext(email, "邮件服务", "发送事务邮件（如 SMTP/SES）")
System_Ext(push, "推送服务", "推送通知（FCM/APNs）")
System_Ext(storage, "文件存储", "本地文件存储")
System_Ext(webrtc, "STUN/TURN", "WebRTC NAT 穿透")
System_Ext(growthbook, "GrowthBook", "A/B 测试与功能开关（可选）")

Rel(user_web, whatschat_sys, "使用", "HTTPS、WebSocket、WebRTC")
Rel(user_mobile, whatschat_sys, "使用", "HTTPS、WebSocket、WebRTC")
Rel(admin_user, whatschat_sys, "管理", "HTTPS")
Rel(whatschat_sys, email, "发送邮件")
Rel(whatschat_sys, push, "发送推送")
Rel(whatschat_sys, storage, "存储/读取文件")
Rel(whatschat_sys, webrtc, "媒体中继")
Rel(whatschat_sys, growthbook, "功能开关、实验", "HTTPS")

SHOW_LEGEND()
@enduml
