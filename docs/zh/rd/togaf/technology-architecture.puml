@startuml
!theme plain
skinparam componentStyle rectangle
skinparam linetype ortho

title TOGAF 技术架构 - WhatsChat 即时通讯系统

package "共享包（Monorepo）" {
  component [@whatschat/domain] as DomainPkg #LightYellow
  note right of DomainPkg
    共享 TypeScript 类型：
    User、Message、Chat、
    Contact、Group、Call
  end note
}

package "客户端技术栈" {
  component [Web 浏览器] as WebBrowser
  component [移动设备] as MobileDevice
  
  package "Web 技术" {
    component [Next.js 15] as NextJS
    component [React 19] as React
    component [TypeScript] as TypeScript
    component [Tailwind CSS] as TailwindCSS
    component [Redux Toolkit + React Redux] as WebState
    component [WebSocket 客户端] as WsClient
    component [WebRTC 客户端] as WebRTCClient
  }
  
  package "管理端技术" {
    component [Next.js 15] as AdminNextJS
    component [React 19] as AdminReact
    component [TypeScript] as AdminTS
    component [Emotion] as Emotion
  }
  
  package "移动端技术" {
    component [React Native] as ReactNative
    component [Expo] as Expo
    component [TypeScript] as MobileTS
    component [Emotion @emotion/native] as MobileEmotion
    component [Redux Toolkit + React Redux] as MobileState
    component [i18next] as i18n
    component [WebSocket 客户端] as MobileWs
    component [WebRTC 客户端] as MobileRTC
  }
}

package "应用服务" {
  component [NestJS 10] as NestJS #LightBlue
  note right of NestJS
    后端框架
    - 模块化架构
    - 依赖注入
    - 信息流、探索、关注（推荐）、互动（点赞/收藏）
  end note
  
  package "核心框架" {
    component [Express] as Express
    component [TypeScript] as ServerTS
    component [Node.js 18+] as NodeJS
  }
  
  package "通信协议" {
    component [REST API] as RestAPI
    component [WebSocket\n(Socket.IO)] as SocketIO
    component [WebRTC 信令] as WebRTCSignal
  }
  
  package "认证与安全" {
    component [JWT] as JWT
    component [Passport] as Passport
    component [bcrypt] as Bcrypt
    component [Helmet] as Helmet
    component [CORS] as CORS
  }
}

package "数据持久化" {
  database [PostgreSQL 13+] as PostgreSQL #LightBlue
  note right of PostgreSQL
    关系型数据库
    - ACID 事务
    - 外键约束
    - 全文搜索
    - JSON 支持
  end note
  
  component [Prisma ORM] as Prisma
  note right of Prisma
    数据库 ORM
    - 类型安全
    - 迁移管理
    - 查询优化
    - Schema 定义
  end note
  
  database [Redis 6+] as Redis #LightCoral
  note right of Redis
    缓存与消息代理
    - 内存存储
    - Pub/Sub
    - 会话存储
    - 信息流缓存
  end note
  
  database [Cassandra] as Cassandra #LightYellow
  note right of Cassandra
    宽表存储
    - 帖子、按用户信息流
    - cassandra-driver
  end note
  
  database [MongoDB] as MongoDB #LightGreen
  note right of MongoDB
    文档存储
    - 评论
  end note
}

package "文件存储" {
  component [本地存储] as FileStorage #LightGreen
  note right of FileStorage
    本地文件存储
    - 文件上传/下载
    - uploadDir
  end note
  
  component [Sharp] as Sharp
  note right of Sharp
    图片处理
    - 缩略图生成
    - 格式转换
    - 缩放
  end note
}

package "搜索服务" {
  database [Elasticsearch] as Elasticsearch #LightYellow
  note right of Elasticsearch
    全文搜索引擎
    - 帖子、用户、话题搜索（游标分页、高亮、限流）
    - 用户：注册/更新入索引；话题：post.created 入索引；同步脚本
    - 模糊匹配
  end note
}

package "消息队列" {
  component [Redis Pub/Sub] as RedisPubSub
  component [Bull Queue] as BullQueue
  component [Kafka] as Kafka
  note right of Kafka
    消息队列
    - KafkaJS
    - 主题：offline-messages、post.created（信息流）
  end note
}

package "推荐技术栈" {
  component [Python 3] as Python
  component [Celery] as Celery
  component [LightFM] as LightFM
  component [implicit] as Implicit
  component [Annoy] as Annoy
  note right of Celery
    批任务（apps/recommendation）
    - Redis broker、beat 调度
    - 推荐、探索热门列表
  end note
}

package "监控与日志" {
  component [Winston] as Winston
  component [健康检查] as HealthCheck
  component [日志轮转] as LogRotate
}

package "部署基础设施" {
  component [Docker] as Docker #LightCyan
  note right of Docker
    容器化部署
    - 应用容器
    - 数据库容器
    - Redis 容器
    - 编排
  end note
  
  component [Docker Compose] as DockerCompose
  component [Nginx] as Nginx
  component [负载均衡] as LoadBalancer
}

\' 共享包被客户端与服务端使用
NextJS --> DomainPkg : 类型
AdminNextJS --> DomainPkg : 类型
ReactNative --> DomainPkg : 类型
NestJS --> DomainPkg : 类型

\' 客户端到服务端
WebBrowser --> NextJS : HTTP/HTTPS
WebBrowser --> SocketIO : WebSocket
WebBrowser --> WebRTCSignal : WebRTC 信令
WebBrowser --> AdminNextJS : HTTP/HTTPS（管理端）
MobileDevice --> ReactNative : 原生应用
ReactNative --> RestAPI : HTTP/HTTPS
ReactNative --> MobileWs : WebSocket
ReactNative --> MobileRTC : WebRTC

NextJS --> React : 框架
NextJS --> TypeScript : 语言
NextJS --> TailwindCSS : 样式
NextJS --> WebState : 状态管理（Redux Toolkit + React Redux）
NextJS --> WsClient : 实时传输
NextJS --> WebRTCClient : 音视频

AdminNextJS --> AdminReact : 框架
AdminNextJS --> AdminTS : 语言
AdminNextJS --> Emotion : 样式

ReactNative --> Expo : 框架
ReactNative --> MobileTS : 语言
ReactNative --> MobileEmotion : 样式
ReactNative --> MobileState : 状态管理（Redux Toolkit + React Redux）
ReactNative --> i18n : i18n（中英）
ReactNative --> MobileWs : 实时传输
ReactNative --> MobileRTC : 音视频

\' 服务端连接
NestJS --> Express : 基于
NestJS --> ServerTS : 语言
NestJS --> NodeJS : 运行时
NestJS --> RestAPI : 暴露
NestJS --> SocketIO : 暴露
NestJS --> WebRTCSignal : 暴露

NestJS --> JWT : 使用
NestJS --> Passport : 使用
NestJS --> Bcrypt : 使用
NestJS --> Helmet : 使用
NestJS --> CORS : 使用

\' 数据层连接
NestJS --> Prisma : 使用
Prisma --> PostgreSQL : 连接
NestJS --> Redis : 连接
NestJS --> RedisPubSub : 使用
NestJS --> BullQueue : 使用
NestJS --> Kafka : 离线消息、post.created
NestJS --> Cassandra : 帖子、信息流、互动
NestJS --> MongoDB : 评论
NestJS --> Redis : 推荐、探索（读）

Celery --> Redis : broker、result
Celery --> Python : 运行于
Python --> LightFM : 混合推荐
Python --> Implicit : ALS
Python --> Annoy : 近似最近邻
Python --> PostgreSQL : ETL（读）
Python --> Cassandra : ETL（读）

\' 服务连接
NestJS --> FileStorage : 文件存储
NestJS --> Sharp : 图片处理
NestJS --> Elasticsearch : 搜索
NestJS --> Winston : 日志
NestJS --> HealthCheck : 监控

\' 部署连接
Docker --> DockerCompose : 编排
Nginx --> LoadBalancer : 参与
Nginx --> NestJS : 反向代理
Docker --> PostgreSQL : 容器化
Docker --> Redis : 容器化
Docker --> Kafka : 容器化

rectangle "技术栈摘要" {
  note as N1
    **前端栈**
    - Web：Next.js + React + TypeScript + Tailwind CSS
    - 管理端：Next.js + React + TypeScript + Emotion
    - 移动端：React Native + Expo + TypeScript + Emotion（@emotion/native）+ i18next
    - 状态管理：Redux Toolkit + React Redux（Web 与移动端）
    - UI：Tailwind CSS（Web）/ Emotion（管理端与移动端）/ 主题（移动端浅色/深色/系统）
    - 实时：WebSocket + WebRTC（Web 与移动端）
  end note
  
  note as N2
    **后端栈**
    - 框架：NestJS（Node.js）
    - 语言：TypeScript
    - 数据库：PostgreSQL + Prisma ORM
    - 缓存：Redis（会话、信息流、推荐、探索）
    - 认证：JWT + Passport
    - 实时：Socket.IO + WebRTC
    - 推荐：Python、Celery、LightFM、implicit、Annoy（批任务写 Redis）
  end note
  
  note as N3
    **基础设施**
    - 容器：Docker + Docker Compose（PostgreSQL、Redis、Kafka、Cassandra、MongoDB、Elasticsearch）
    - 反向代理：Nginx
    - 负载均衡：Nginx/云厂商
    - 文件存储：本地
    - 搜索：Elasticsearch
    - 日志：Winston
  end note
}

note bottom
  **技术架构说明**
  
  WhatsChat 采用现代技术栈：
  
  1. **客户端** – Web 应用（Next.js + React）；管理端（Next.js + React + Emotion）；移动端（React Native + Expo + Emotion + i18next、主题）
  2. **服务端** – NestJS 提供模块化、可扩展的后端服务
  3. **数据层** – PostgreSQL 为主库；Redis 做缓存、Pub/Sub、推荐/探索缓存、Celery broker；Cassandra 存帖子、信息流、互动；MongoDB 存评论；Elasticsearch 做搜索
  4. **推荐** – Python（Celery、LightFM、implicit、Annoy）批任务将推荐与探索列表写入 Redis；API 从 Redis 读取
  5. **协议** – REST API 同步调用、WebSocket 实时消息、WebRTC 音视频
  6. **安全** – JWT 认证、bcrypt 密码哈希、Helmet 安全头、CORS 控制
  7. **存储** – 本地文件存储、Elasticsearch 全文搜索
  8. **部署** – 基于 Docker 的容器化，覆盖开发、测试、生产
  
  技术选型侧重性能、可扩展性、安全与开发效率。
end note

@enduml
