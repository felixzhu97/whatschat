@startuml Wardley_Map_WhatsFeed

!theme plain

skinparam linetype ortho
skinparam packageStyle rectangle

title WhatsFeed 社交平台 - 沃德利地图 (Wardley Map)\n' 价值链（Y轴）：用户需求 → 应用 → 平台 → 基础设施\n' 演化轴（X轴）：Genesis → Custom Built → Product → Commodity

' ============================================
' 第四层：用户需求层（最上方）
' ============================================
package "用户需求层 (User Needs)" #E3F2FD {
  class UserMessaging <<(U,#1E88E5) 用户需求>> {
    + 即时通讯需求
    + 社交动态需求
    + 音视频通话需求
    + 内容创作需求
    + 文件分享需求
    + 发现与推荐需求
    + AI 助手需求
  }
}

' ============================================
' 第三层：应用层
' ============================================
package "应用层 (Applications)" #BBDEFB {
  class WebApp <<(A,#1976D2) Web应用>> {
    + Next.js 15 + React 19
    + Instagram 风格 UI
    + Emotion + Redux Toolkit
    + Tailwind CSS
    + 实时消息界面
    + 动态发布与浏览
  }

  class MobileApp <<(A,#1976D2) 移动应用>> {
    + React Native + Expo
    + iOS/Android 双平台
    + 原生体验优化
    + 推送通知集成
    + 离线消息同步
    + 媒体播放
  }

  class AdminApp <<(A,#1976D2) 管理后台>> {
    + 用户管理
    + 内容审核
    + 数据分析看板
    + 系统配置
    + Bootstrap + AG Grid
  }
}

' ============================================
' 第二层：平台服务层
' ============================================
package "平台服务层 (Platform Services)" #90CAF9 {
  class MessageService <<(S,#1565C0) 消息服务>> {
    + Socket.IO 实时通信
    + 消息持久化
    + 消息状态管理
    + 离线消息队列
    + Kafka 消息分发
  }

  class AuthService <<(S,#1565C0) 认证授权服务>> {
    + JWT 令牌管理
    + Passport 多策略
    + 用户会话管理
    + 权限控制
    + 第三方登录
  }

  class CallService <<(S,#1565C0) 通话服务>> {
    + WebRTC 信令服务
    + 通话状态管理
    + 媒体协商
    + 通话记录
    + STUN/TURN 集成
  }

  class PostService <<(S,#1565C0) 内容服务>> {
    + 动态发布/编辑/删除
    + 多媒体上传
    + 评论与点赞
    + 收藏功能
    + 话题标签
  }

  class MediaService <<(S,#1565C0) 媒体处理服务>> {
    + 图片生成 (Stable Diffusion)
    + 视频生成 (CogVideoX)
    + 语音合成 (edge-tts)
    + 图片压缩/裁剪
  }

  class SearchService <<(S,#1565C0) 搜索服务>> {
    + Elasticsearch 全文检索
    + 用户/帖子搜索
    + 消息历史搜索
    + 话题搜索
  }

  class NotificationService <<(S,#1565C0) 推送通知服务>> {
    + FCM/APNs 集成
    + 实时推送
    + 离线通知
    + 推送统计
  }

  class RecommendationService <<(S,#1565C0) 推荐服务>> {
    + 关注推荐 (LightFM)
    + Feed 排序 (PyTorch)
    + 探索流推荐
    + 冷启动处理
  }

  class VisionService <<(S,#1565C0) 内容审核服务>> {
    + NSFW 检测 (NudeNet)
    + 标签推荐
    + 复审管理
    + 质量评估
  }

  class RAGService <<(S,#1565C0) RAG 问答服务>> {
    + 文档语义搜索
    + LLM 生成答案
    + 流式响应
    + 多源查询
  }
}

' ============================================
' 第一层：基础设施层（最下方）
' ============================================
package "基础设施层 (Infrastructure)" #64B5F6 {
  class PostgreSQL <<(I,#0D47A1) PostgreSQL>> {
    + 主数据库
    + Prisma ORM
    + 读写分离
  }

  class Redis <<(I,#0D47A1) Redis>> {
    + 缓存服务
    + 会话存储
    + 消息队列
    + 推荐结果缓存
  }

  class Cassandra <<(I,#0D47A1) Cassandra>> {
    + 时序数据存储
    + 互动数据 (点赞/评论)
    + 高写入吞吐
  }

  class MongoDB <<(I,#0D47A1) MongoDB>> {
    + 文件元数据
    + 媒体信息
    + 灵活文档存储
  }

  class Elasticsearch <<(I,#0D47A1) Elasticsearch>> {
    + 全文索引
    + 日志存储
    + 搜索优化
  }

  class ObjectStorage <<(I,#0D47A1) 对象存储>> {
    + 媒体文件存储
    + CDN 集成
    + 备份存储
  }

  class CDN <<(I,#0D47A1) CDN>> {
    + 静态资源加速
    + 全球分发
    + 缓存策略
  }

  class WebSocket <<(I,#0D47A1) WebSocket>> {
    + Socket.IO
    + 实时通信
    + 连接管理
  }

  class ContainerService <<(I,#0D47A1) 容器服务>> {
    + Docker 容器化
    + K8s 编排
    + 自动扩缩容
  }

  class Qdrant <<(I,#0D47A1) Qdrant>> {
    + 向量数据库
    + RAG 语义搜索
    + 相似度检索
  }

  class Ollama <<(I,#0D47A1) Ollama>> {
    + 本地 LLM
    + 文本嵌入
    + 流式生成
  }
}

' ============================================
' 演化阶段标注
' ============================================

' Genesis 阶段（创新） - 左侧
package "Genesis (创新)" #FFF9C4 {
  class AIAssistant <<(G,#F9A825) AI 助手>> {
    + 智能回复建议
    + 内容理解
    + 情感分析
    + 对话生成
  }

  class ContentGeneration <<(G,#F9A825) 内容生成>> {
    + AI 图片生成
    + AI 视频生成
    + AI 语音合成
    + 风格迁移
  }

  class RAGQA <<(G,#F9A825) RAG 问答>> {
    + 语义搜索
    + 上下文理解
    + 知识库问答
    + 流式响应
  }

  class AdvancedRecommendations <<(G,#F9A825) 高级推荐>> {
    + 深度学习排序
    + 多目标优化
    + 实时个性化
    + 冷启动推荐
  }
}

' Custom Built 阶段（定制构建） - 中左
package "Custom Built (定制构建)" #FFE0B2 {
  class RealtimeMessaging <<(C,#FB8C00) 实时消息>> {
    + Socket.IO 定制
    + 消息路由逻辑
    + 离线同步策略
    + 已读回执
  }

  class WebRTCCalls <<(C,#FB8C00) WebRTC 通话>> {
    + 信令服务定制
    + 通话质量优化
    + 弱网自适应
    + 多人通话
  }

  class PostEngagement <<(C,#FB8C00) 社交互动>> {
    + 动态发布流程
    + 评论嵌套
    + 点赞/收藏逻辑
    + 分享机制
  }

  class ContentModeration <<(C,#FB8C00) 内容审核>> {
    + NSFW 检测集成
    + 人工复审流程
    + 标签推荐算法
    + 申诉处理
  }
}

' Product 阶段（产品化） - 中右
package "Product (产品化)" #C8E6C9 {
  class WebApplication <<(P,#43A047) Web 应用>> {
    + Next.js 框架
    + 标准化 UI 组件
    + Redux 状态管理
  }

  class MobileApplication <<(P,#43A047) 移动应用>> {
    + React Native
    + Expo 标准化
    + 跨平台适配
  }

  class AuthPlatform <<(P,#43A047) 认证平台>> {
    + JWT 标准方案
    + Passport 策略
    + OAuth 集成
  }

  class SearchPlatform <<(P,#43A047) 搜索平台>> {
    + Elasticsearch
    + 标准化分词
    + 搜索建议
  }

  class PushNotification <<(P,#43A047) 推送通知>> {
    + FCM 集成
    + APNs 集成
    + 消息模板
  }
}

' Commodity 阶段（商品化） - 右侧
package "Commodity (商品化)" #E1BEE7 {
  class Databases <<(D,#7B1FA2) 数据库服务>> {
    + PostgreSQL
    + Redis 缓存
    + MongoDB
    + Cassandra
  }

  class Storage <<(D,#7B1FA2) 存储服务>> {
    + S3/OSS 对象存储
    + CDN 分发
    + 备份服务
  }

  class Containers <<(D,#7B1FA2) 容器服务>> {
    + Docker
    + Kubernetes
    + 容器编排
  }

  class VectorStore <<(D,#7B1FA2) 向量数据库>> {
    + Qdrant
    + 向量检索
    + 近似搜索
  }
}

' ============================================
' 依赖关系
' ============================================

' 用户需求 → 应用层
UserMessaging --> WebApp : 使用
UserMessaging --> MobileApp : 使用

' 应用层 → 平台服务层
WebApp --> MessageService : 依赖
WebApp --> AuthService : 依赖
WebApp --> PostService : 依赖
WebApp --> SearchService : 依赖
WebApp --> NotificationService : 依赖

MobileApp --> MessageService : 依赖
MobileApp --> AuthService : 依赖
MobileApp --> PostService : 依赖
MobileApp --> NotificationService : 依赖
MobileApp --> CallService : 依赖

AdminApp --> AuthService : 依赖
AdminApp --> VisionService : 依赖

' 平台服务层 → 基础设施层
MessageService --> Redis : 需要
MessageService --> WebSocket : 需要
MessageService --> Kafka : 需要

AuthService --> PostgreSQL : 需要
AuthService --> Redis : 需要

CallService --> WebSocket : 需要

PostService --> PostgreSQL : 需要
PostService --> Redis : 需要
PostService --> MediaService : 需要
PostService --> VisionService : 需要

MediaService --> ObjectStorage : 需要
MediaService --> CDN : 需要

SearchService --> Elasticsearch : 需要

NotificationService --> WebSocket : 需要

RecommendationService --> Redis : 需要
RecommendationService --> Cassandra : 需要
RecommendationService --> PostgreSQL : 需要

VisionService --> PostgreSQL : 需要

RAGService --> Qdrant : 需要
RAGService --> Ollama : 需要

' 基础设施内部依赖
ObjectStorage --> CDN : 使用
ContainerService --> Databases : 托管
ContainerService --> Redis : 托管

' Genesis 组件依赖
AIAssistant --> Ollama : 需要
ContentGeneration --> Ollama : 需要
RAGQA --> Ollama : 需要
RAGQA --> Qdrant : 需要
AdvancedRecommendations --> Ollama : 需要

' ============================================
' 战略演进说明
' ============================================

note top of AIAssistant
  **Genesis 战略要点**
  - AI 能力是核心差异化
  - 持续投入模型优化
  - 探索新 AI 应用场景
end note

note top of RealtimeMessaging
  **Custom Built 战略要点**
  - 实时消息是平台核心
  - 保持技术领先
  - 优化用户体验
end note

note top of WebApplication
  **Product 战略要点**
  - 采用成熟技术栈
  - 平衡开发效率
  - 保持灵活性
end note

note top of Databases
  **Commodity 战略要点**
  - 使用托管服务降低运维
  - 专注于核心业务
  - 成本优化重点
end note

