#!/bin/sh

echo "Running pre-push checks..."

# Run type check for apps
echo "Running TypeScript checks..."
pnpm --filter whatschat-web check-types
if [ $? -ne 0 ]; then
  echo "TypeScript check failed for web!"
  exit 1
fi

pnpm --filter whatschat-admin check-types
if [ $? -ne 0 ]; then
  echo "TypeScript check failed for admin!"
  exit 1
fi

pnpm --filter react-native-app check-types
if [ $? -ne 0 ]; then
  echo "TypeScript check failed for mobile!"
  exit 1
fi

echo "All checks passed!"
